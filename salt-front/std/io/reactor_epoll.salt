// =============================================================================
// std.io.EpollReactor — Linux epoll backend for the Reactor trait
// =============================================================================
// Stub implementation for Linux portability.
// All methods currently return -1 (not implemented).
//
// When targeting Linux, this file will use raw epoll_ctl / epoll_wait
// syscalls via the same FFI pattern as KqueueReactor uses for kqueue.

package std.io.reactor_epoll

use std.core.ptr.Ptr
use std.core.result.Result
use std.status.Status
use std.io.reactor.{Reactor, Filter}

/// Linux epoll-backed I/O reactor.
/// Stub: returns errors until Linux support is implemented.
pub struct EpollReactor {
    epfd: i32
}

impl EpollReactor {
    /// Create a new EpollReactor.
    /// Currently fails unconditionally — epoll not yet implemented.
    pub fn new() -> Result<EpollReactor> {
        // TODO: epoll_create1(EPOLL_CLOEXEC) when targeting Linux
        return Result::Err(Status::internal("EpollReactor: Linux epoll backend not yet implemented"));
    }
}

impl Reactor for EpollReactor {
    pub fn register(&self, fd: i32, filter: Filter) -> i32 {
        // TODO: epoll_ctl(self.epfd, EPOLL_CTL_ADD, fd, &ev)
        return -1;
    }

    pub fn deregister(&self, fd: i32) -> i32 {
        // TODO: epoll_ctl(self.epfd, EPOLL_CTL_DEL, fd, null)
        return -1;
    }

    pub fn wait(&self, event_buf: Ptr<i64>, max_events: i32, timeout_ms: i32) -> i32 {
        // TODO: epoll_wait(self.epfd, events, max_events, timeout_ms)
        return -1;
    }

    pub fn fd(&self) -> i32 {
        return self.epfd;
    }
}
