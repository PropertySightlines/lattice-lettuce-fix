package main

extern fn malloc(size: i64) -> Ptr<u8>;
extern fn free(ptr: Ptr<u8>);

struct Config { dim: i64 }
struct TransformerWeights { w1: Ptr<f32> }
struct RunState { logits: Ptr<f32> }

struct EngineState {
    config: Config,
    weights: TransformerWeights,
    state: RunState
}

fn forward(cfg: Config, w: TransformerWeights, s: RunState) {}

fn main() -> i32 {
    let es_ptr = malloc(1024);
    let es = es_ptr as Ptr<EngineState>;
    
    // This is what triggered the numeric promotion error
    forward(es.config, es.weights, es.state);
    
    free(es_ptr);
    return 0;
}
