// Sovereign Arena: Thread-Local Slab Allocator
// O(1) allocation via pointer-bump. O(1) reset at pulse boundaries.
// 128-byte aligned to prevent false sharing on M4 performance cores.
//
// Memory Hierarchy:
//   SovereignArena → General-purpose task allocation
//   DmaArena       → NIC-mapped pinned memory for zero-copy I/O

package std.mem.arena

// ============================================================================
// SovereignArena: Pointer-Bump Allocator
// ============================================================================

const ARENA_ALIGNMENT: i64 = 128;   // M4 cache line (prevent false sharing)
const DEFAULT_ARENA_SIZE: i64 = 1048576;  // 1MB default

struct SovereignArena {
    base: Ptr<u8>,       // Start of the allocated region
    cursor: i64,         // Current allocation offset (the "hot pointer")
    capacity: i64,       // Total arena size in bytes
    alloc_count: i64,    // Diagnostic: total allocations
}

impl SovereignArena {
    // Initialize a new arena with the given capacity
    fn new(capacity: i64) -> SovereignArena {
        // Arena memory is allocated from the OS at startup
        // In production: mmap with MAP_ANONYMOUS
        let base = intrinsics::sovereign_arena_alloc(capacity);
        return SovereignArena {
            base: base as Ptr<u8>,
            cursor: 0,
            capacity: capacity,
            alloc_count: 0,
        };
    }

    // Allocate `size` bytes with 128-byte alignment
    // Cost: ~2ns (single pointer increment + alignment mask)
    fn alloc(self: &mut SovereignArena, size: i64) -> Ptr<u8> {
        // Align cursor up to ARENA_ALIGNMENT boundary
        let aligned_cursor = (self.cursor + ARENA_ALIGNMENT - 1) & (!(ARENA_ALIGNMENT - 1));
        let new_cursor = aligned_cursor + size;

        if new_cursor > self.capacity {
            // Arena exhaustion — this should never happen in well-sized systems
            // The scheduler should reset before we get here
            return 0 as Ptr<u8>;
        }

        self.cursor = new_cursor;
        self.alloc_count = self.alloc_count + 1;
        return self.base.offset(aligned_cursor);
    }

    // Allocate a TaskFrame of the given size
    // TaskFrames are typically < 64 bytes (fits in one cache line)
    fn alloc_frame(self: &mut SovereignArena, frame_size: i64) -> Ptr<u8> {
        return self.alloc(frame_size);
    }

    // O(1) arena reset: reclaim all memory at once
    // Called at pulse boundaries by the executor
    fn reset(self: &mut SovereignArena) {
        self.cursor = 0;
        // Note: we don't zero memory — the allocator doesn't guarantee
        // clean memory, and the state machine initializes fields explicitly
    }

    // How many bytes have been consumed
    fn used(self: &SovereignArena) -> i64 {
        return self.cursor;
    }

    // How many bytes remain
    fn remaining(self: &SovereignArena) -> i64 {
        return self.capacity - self.cursor;
    }
}

// ============================================================================
// DmaArena: NIC-Mapped Pinned Memory
// ============================================================================
//
// Physical constraints:
//   - Memory is mlock'd (never swapped, NIC hardware expects stable addresses)
//   - 16KB page-aligned (M4 standard page size)
//   - Ring of SovereignBuffers for zero-copy I/O
//

const DMA_PAGE_SIZE: i64 = 16384;    // M4 16KB page
const DMA_BUFFER_SIZE: i64 = 4096;   // Standard MTU-aligned buffer
const DMA_RING_SIZE: i64 = 4096;     // Number of buffers in the ring

struct DmaArena {
    base: Ptr<u8>,           // mlock'd region base
    total_size: i64,         // Total mapped bytes
    ring_head: i64,          // Next buffer to hand to NIC (RX)
    ring_tail: i64,          // Next buffer returned from task (TX/free)
    buffer_count: i64,       // Total buffers in the ring
}

impl DmaArena {
    // Initialize a DMA arena with the given number of pages
    // Each page is 16KB, pre-faulted and locked to physical RAM
    fn new(num_pages: i64) -> DmaArena {
        let total = num_pages * DMA_PAGE_SIZE;
        let base = intrinsics::sovereign_arena_alloc(total);

        let buf_count = total / DMA_BUFFER_SIZE;

        return DmaArena {
            base: base as Ptr<u8>,
            total_size: total,
            ring_head: 0,
            ring_tail: 0,
            buffer_count: buf_count,
        };
    }
}

// Implement DMA_Provider for DmaArena
impl DmaArena {
    // Acquire the next available buffer from the ring
    // After this call, the application owns the buffer
    fn acquire_buffer(self: &mut DmaArena) -> SovereignBuffer {
        let idx = self.ring_head % self.buffer_count;
        self.ring_head = self.ring_head + 1;

        let buf_offset = idx * DMA_BUFFER_SIZE;
        return SovereignBuffer {
            data: self.base.offset(buf_offset),
            capacity: DMA_BUFFER_SIZE,
            length: 0,        // NIC hasn't written yet
            offset: 0,
        };
    }

    // Release a buffer back to the NIC's ring
    // The NIC will reuse this memory for future RX
    fn release_to_nic(self: &mut DmaArena, buf: SovereignBuffer) {
        let idx = self.ring_tail % self.buffer_count;
        self.ring_tail = self.ring_tail + 1;
        // The buffer pointer is already in the DMA region,
        // so no copy is needed — just advance the tail
    }
}

// ============================================================================
// Delayed Free Mailbox: Lock-Free Cross-Thread Memory Return
// ============================================================================
//
// When a task completes on Core B but its TaskFrame was allocated
// on Core A's arena, we can't free it directly (that would require a lock).
// Instead, we post it to Core A's mailbox using atomic SWP.
//
// Core A drains its mailbox periodically, recycling memory locally.

const MAILBOX_CAPACITY: i64 = 256;

struct DelayedFreeMailbox {
    slots: [Ptr<u8>; 256],
    head: i64,   // Atomic: producers (any core) push here
    tail: i64,   // Only the owning core reads from here
}

impl DelayedFreeMailbox {
    fn new() -> DelayedFreeMailbox {
        return DelayedFreeMailbox {
            slots: [0 as Ptr<u8>; 256],
            head: 0,
            tail: 0,
        };
    }

    // Post a pointer to the owning core's mailbox (lock-free)
    // Uses atomic_add_i64 to claim a slot
    fn post(self: &mut DelayedFreeMailbox, ptr: Ptr<u8>) -> bool {
        let slot = intrinsics::atomic_add_i64(&self.head, 1);
        let idx = slot % MAILBOX_CAPACITY;

        if idx == self.tail % MAILBOX_CAPACITY {
            return false;  // Mailbox full — rare, task should retry
        }

        self.slots[idx] = ptr;
        return true;
    }

    // Return a TaskFrame to its owner's arena via Treiber stack CAS loop
    // This is the cross-core return path. The frame's "next" pointer is
    // stored at offset 0 of the frame (overlapping resume_state, which is
    // -1 = completed at this point).
    fn return_to_sender(self: &mut DelayedFreeMailbox, frame: Ptr<u8>) -> bool {
        // Treiber stack push: CAS loop
        // 1. Read current head
        // 2. Set frame.next = head  (frame is completed, resume_state=-1)
        // 3. CAS(head, old_head, frame)
        // Retry on contention
        let mut attempts: i64 = 0;
        while attempts < 16 {
            let old_head = intrinsics::atomic_load_i64(&self.head as Ptr<u8>);
            // Store old_head as the "next" pointer in the frame
            // (At offset 0 — overlapping the now-unused resume_state)
            intrinsics::atomic_store_i64(frame, old_head);
            // CAS: try to make this frame the new head
            let result = intrinsics::atomic_cas_ptr(
                &self.head as Ptr<u8>,
                old_head as Ptr<u8>,
                frame
            );
            if result == old_head as Ptr<u8> {
                return true;  // Successfully pushed
            }
            attempts = attempts + 1;
            // Contention: another core pushed first, retry
        }
        return false;  // Gave up after 16 attempts (extremely rare)
    }

    // Drain the mailbox (called by the owning core during idle)
    // Returns the number of pointers reclaimed
    fn drain(self: &mut DelayedFreeMailbox, arena: &mut SovereignArena) -> i64 {
        let mut count: i64 = 0;
        while self.tail != self.head {
            let idx = self.tail % MAILBOX_CAPACITY;
            let _ptr = self.slots[idx];
            // In a real implementation, we'd return this to the arena's free list
            // For now, the arena uses full-reset semantics
            self.tail = self.tail + 1;
            count = count + 1;
        }
        return count;
    }

    // Drain the Treiber stack mailbox (atomic swap + walk)
    // Single-consumer: only the owning core calls this
    // Returns the count of frames recovered
    fn drain_treiber(self: &mut DelayedFreeMailbox, arena: &mut SovereignArena) -> i64 {
        // Atomic swap: grab entire chain in one operation
        let chain = intrinsics::atomic_cas_ptr(
            &self.head as Ptr<u8>,
            intrinsics::atomic_load_i64(&self.head as Ptr<u8>) as Ptr<u8>,
            0 as Ptr<u8>  // Replace with null = empty
        );

        // Walk the chain, each node's offset-0 is the next pointer
        let mut current = chain;
        let mut count: i64 = 0;
        while current != 0 as Ptr<u8> {
            let next = intrinsics::atomic_load_i64(current) as Ptr<u8>;
            // The frame is returned to the arena (arena handles recycling)
            // For now, just count — arena uses bulk reset
            current = next;
            count = count + 1;
        }
        return count;
    }

    // Number of pending items in the mailbox
    fn pending_count(self: &DelayedFreeMailbox) -> i64 {
        return self.head - self.tail;
    }
}

// Import SovereignBuffer for DmaArena methods
import std.net.buffer.SovereignBuffer
