package kernel.core.main

import kernel.arch.x86.gdt
import kernel.arch.x86.idt
import kernel.drivers.pit
import kernel.core.io
import kernel.drivers.serial
import kernel.drivers.vga
import kernel.core.scheduler
import std.test
import kernel.core.panic
import kernel.sched.affinity
import kernel.core.context_switch
import benchmarks.ring_of_fire
import benchmarks.ring_of_fire_1k
import benchmarks.syscall_bench
import benchmarks.ipc_bench
import benchmarks.alloc_bench
import kernel.core.timing

// IPC responder fiber — defined in ipc_bench.salt with @no_mangle
extern fn ipc_responder();


