package kernel.core.main

import kernel.arch.x86.gdt
import kernel.arch.x86.idt
import kernel.arch.x86.tss
import kernel.drivers.pit
import kernel.core.io
import kernel.drivers.serial
import kernel.drivers.vga
import kernel.core.scheduler
import kernel.core.panic
import kernel.core.pmm
import kernel.core.process
import kernel.core.syscall
import kernel.core.exec_user
import kernel.core.memory
import kernel.mem.slab_cache
import kernel.core.vma
import kernel.core.dispatcher



// Assembly FFI (unmangled symbols)
extern fn read_cr3() -> u64;
extern fn idle_halt();
extern fn proc_context_switch(old_rsp_ptr: u64, new_rsp: u64, new_cr3: u64, new_rsp0: u64);
extern fn get_user_elf_a_addr() -> u64;
extern fn get_user_elf_b_addr() -> u64;
extern fn get_kernel_event_loop_addr() -> u64;

// Local copies of process constants
const MAX_PROCS: u64   = 16;
const PROC_RUNNING: u64 = 2;

@no_mangle
pub fn salt_yield_check() {
}

@no_mangle
pub fn kmain(magic: u32, mb_info: &u8) {
    serial.init();
    serial.print("LATTICE BOOT: Serial OK\n");

    serial.print("LATTICE BOOT: GDT...\n");
    gdt.init();
    serial.print("LATTICE BOOT: IDT...\n");
    idt.init();
    serial.print("LATTICE BOOT: PIT...\n");
    pit.init();
    serial.print("LATTICE BOOT: Scheduler...\n");
    scheduler.init();

    // PMM: 32MB-64MB physical (per mm_layout.salt)
    serial.print("LATTICE BOOT: PMM...\n");
    pmm.init(0x2000000, 0x4000000);
    serial.print("LATTICE BOOT: Slab Cache...\n");
    slab_cache.init();
    serial.print("LATTICE BOOT: VMA...\n");
    vma.init();
    serial.print("LATTICE KERNEL BOOT [OK]\n");

    vga.clear();
    vga.print_colored(" LATTICE OS v0.6 ", 0x1F);
    vga.print("\n");

    scheduler.start();
    serial.print("[Lattice] PREEMPTIVE MODE\n");

    // GDT/TSS for Ring 3
    let kernel_rsp0: u64 = 0xFFFFFFFF80126000;
    tss.init_tss(kernel_rsp0);
    let tss_addr = tss.get_tss_addr();
    gdt.init_ring3(tss_addr);
    serial.print("[Lattice] GDT/TSS Ring 3 ready\n");

    // Save kernel PML4
    let kernel_pml4 = read_cr3();
    syscall.set_kernel_pml4(kernel_pml4);

    // =========================================================================
    // SPAWN TASK 0: Immortal Ring 0 Dispatcher Thread
    // =========================================================================
    // Task 0 MUST be slot 0. It runs kernel_event_loop() in Ring 0 with IF=1.
    // It drains the PulseEvent queue and yields when empty.
    // =========================================================================
    let task0_entry = get_kernel_event_loop_addr();
    let slot_task0 = exec_user.spawn_kernel_thread(task0_entry, kernel_pml4);
    process.set_state(slot_task0, PROC_READY);
    serial.print("[Lattice] Task 0 (dispatcher) spawned\n");

    // Spawn Ring 3 user processes
    serial.print("[Lattice] SPAWNING PROCESSES\n");

    let elf_a = get_user_elf_a_addr();
    let slot_a = exec_user.spawn_process(elf_a, kernel_pml4);
    serial.print("[Lattice] Process A spawned\n");

    let elf_b = get_user_elf_b_addr();
    let slot_b = exec_user.spawn_process(elf_b, kernel_pml4);
    process.set_state(slot_b, PROC_READY);
    serial.print("[Lattice] Process B spawned\n");

    // Start first user process (not Task 0 — Task 0 will be scheduled reactively)
    if slot_a < MAX_PROCS {
        process.set_current(slot_a);
        process.set_state(slot_a, PROC_RUNNING);

        let new_rsp  = process.get_kernel_rsp(slot_a);
        let new_cr3  = process.get_pml4(slot_a);
        let new_rsp0 = process.get_kernel_stack_top(slot_a);

        // Set TSS.RSP0 with virtual address for Ring 3 → Ring 0 transitions
        tss.set_rsp0(new_rsp0);

        let dummy: u64 = 0;
        serial.print("[Lattice] Switching to first process...\n");
        proc_context_switch((&dummy) as u64, new_rsp, new_cr3, new_rsp0);
    }

    serial.print("[Lattice] All processes complete. Idle.\n");
    loop {
        idle_halt();
    }
}
