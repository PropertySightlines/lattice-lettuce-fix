package kernel.core.scheduler

import kernel.core.pmm
import kernel.sched.affinity
import std.test
import kernel.drivers.serial
import kernel.core.pulse

// Cross-module extern declarations (avoids linker error during standalone compilation)
extern fn ctz_u64(x: u64) -> u64;
extern fn stack_init(stack_top: u64, entry: u64) -> u64;

// Slab allocator — lock-free Treiber stack (kernel/mem/slab.salt)
extern fn pop_stack() -> u64;
extern fn push_stack(ptr: u64);

// =============================================================================
// Kernel Scheduler — O(1) Multi-Level Bitmap with Stack Reclamation
// =============================================================================
//
// Uses a 2-level bitmap to find the next runnable fiber in O(1) via hardware
// TZCNT instruction (llvm.intr.cttz). Supports up to 1024 fibers.
//
// L1 summary: 1 bit per group of 64 fibers (16 groups for 1024 fibers)
// L2 details: 1 bit per fiber within each group
//
// Stack Lifecycle:
//   spawn()      → pop_stack()   (allocate 16KB slab slot)
//   fiber_exit() → push_stack()  (reclaim 16KB slab slot, deferred)
//
// Deferred Reclamation Protocol:
//   fiber_exit() cannot call push_stack() while still executing on the dying
//   fiber's stack. Instead, it stores the stack base in PENDING_RECLAIM and
//   yields. The NEXT fiber to resume from sched_yield() performs the actual
//   push_stack() call, safely executing on its own stack.
// =============================================================================

const MAX_FIBERS: u64 = 1024;
const SLAB_SLOT_SIZE: u64 = 16384; // mm_layout.SLAB_SLOT_SIZE
const L2_GROUPS: u64 = 16;
const ALL_ONES: u64 = 0xFFFFFFFFFFFFFFFF;

pub struct Fiber {
    pub id: u64,
    pub stack_ptr: u64,
    pub stack_base: u64,
    pub active: bool,
}

pub struct SchedulerState {
    pub fibers: [Fiber; 1024],
    pub current: u64,
    pub count: u64,
    pub next_id: u64,
    pub yield_pending: bool,
    pub l1_summary: u64,
    pub l2_details: [u64; 16],
}

global GLOBAL_SCHED: SchedulerState = SchedulerState {
    fibers: [Fiber { id: 0, stack_ptr: 0, stack_base: 0, active: false }; 1024],
    current: 0,
    count: 0,
    next_id: 1,
    yield_pending: false,
    l1_summary: 0,
    l2_details: [0 as u64; 16]
};

// Deferred reclamation: stack base address of the most recently dead fiber.
// Zeroed after reclamation. Only one fiber can die per sched_yield cycle
// in single-core mode, so a single slot suffices.
global PENDING_RECLAIM: u64 = 0;


extern fn switch_stacks(old_sp_ptr: *mut u64, new_sp: u64);

@no_mangle
pub fn timer_isr() {
    region("sched_tick") {
        // Increment monotonic tick counter
        pulse.tick();

        // Enqueue a structured PulseEvent for the dispatcher
        pulse.push(pulse.PULSE_TIMER, pulse.get_tick());

        // Set yield flag for preemptive scheduling
        GLOBAL_SCHED.yield_pending = true;
    }
}

pub fn init() {
    region("sched_init") {
       GLOBAL_SCHED.fibers[0].active = true;
       GLOBAL_SCHED.fibers[0].id = 0;
       GLOBAL_SCHED.fibers[0].stack_base = 0;
       GLOBAL_SCHED.current = 0;
       GLOBAL_SCHED.yield_pending = false;

       // Mark fiber 0 as active in bitmap
       GLOBAL_SCHED.l2_details[0] = 1 as u64;
       GLOBAL_SCHED.l1_summary = 1 as u64;
    }
}

// Mark a fiber as READY in the bitmap
fn bitmap_set(fiber_id: u64) {
    let l1_idx = fiber_id / 64;
    let l2_bit = fiber_id % 64;
    let bit_mask: u64 = (1 as u64) << l2_bit;

    let old_l2 = GLOBAL_SCHED.l2_details[l1_idx];
    GLOBAL_SCHED.l2_details[l1_idx] = old_l2 | bit_mask;

    let group_mask: u64 = (1 as u64) << l1_idx;
    let old_l1 = GLOBAL_SCHED.l1_summary;
    GLOBAL_SCHED.l1_summary = old_l1 | group_mask;
}

// Mark a fiber as BLOCKED/EMPTY in the bitmap
fn bitmap_clear(fiber_id: u64) {
    let l1_idx = fiber_id / 64;
    let l2_bit = fiber_id % 64;
    let bit_mask: u64 = (1 as u64) << l2_bit;
    let inv_mask: u64 = bit_mask ^ ALL_ONES;

    let old_l2 = GLOBAL_SCHED.l2_details[l1_idx];
    let new_l2 = old_l2 & inv_mask;
    GLOBAL_SCHED.l2_details[l1_idx] = new_l2;

    if new_l2 == 0 {
        let group_mask: u64 = (1 as u64) << l1_idx;
        let inv_group: u64 = group_mask ^ ALL_ONES;
        let old_l1 = GLOBAL_SCHED.l1_summary;
        GLOBAL_SCHED.l1_summary = old_l1 & inv_group;
    }
}

// Build a mask of all bits strictly above position `bit`
fn mask_above_bit(bit: u64) -> u64 {
    if bit >= 63 {
        return 0;
    }
    let shift = bit + 1;
    let below: u64 = ((1 as u64) << shift) - 1;
    return below ^ ALL_ONES;
}

// Build a mask of all bits strictly below position `bit`
fn mask_below_bit(bit: u64) -> u64 {
    if bit == 0 {
        return 0;
    }
    return ((1 as u64) << bit) - 1;
}

pub fn spawn(entry_addr: u64) -> u64 {
    region("sched_spawn") {
        // O(1) free slot lookup via inverted bitmap
        let mut group: u64 = 0;
        let mut found = false;
        let mut slot: u64 = 0;

        while group < L2_GROUPS {
            let l2_val = GLOBAL_SCHED.l2_details[group];
            let free_mask = l2_val ^ ALL_ONES;
            if free_mask != 0 {
                let bit = ctz_u64(free_mask);
                slot = group * 64 + bit;
                if slot < MAX_FIBERS {
                    found = true;
                    group = L2_GROUPS;  // break
                }
            }
            group = group + 1;
        }
        
        if found {
            GLOBAL_SCHED.fibers[slot].id = GLOBAL_SCHED.next_id;
            GLOBAL_SCHED.fibers[slot].active = true;
            
            // Allocate a 16KB stack from the slab allocator
            let stack_base = pop_stack();
            let stack_top = stack_base + SLAB_SLOT_SIZE;

            GLOBAL_SCHED.fibers[slot].stack_base = stack_base;
            GLOBAL_SCHED.fibers[slot].stack_ptr = stack_init(stack_top, entry_addr);
            
            GLOBAL_SCHED.next_id = GLOBAL_SCHED.next_id + 1;
            GLOBAL_SCHED.count = GLOBAL_SCHED.count + 1;

            // Update bitmap
            bitmap_set(slot);

            return slot;
        } else {
            return 9999;
        }
    }
    return 0;
}

extern fn enable_interrupts();

pub fn start() {
    region("sched_start") {
        enable_interrupts();
    }
}

// =============================================================================
// fiber_exit — Clean Fiber Termination with Deferred Stack Reclamation
// =============================================================================
// Called by a fiber when it has completed its work. Must be called explicitly
// by the fiber (or via a trampoline on the initial stack frame).
//
// Protocol:
//   1. Read the current fiber's slot and slab base address.
//   2. Store the slab base in PENDING_RECLAIM for deferred push_stack().
//   3. Mark the fiber inactive, clear the bitmap, decrement count.
//   4. Yield — the scheduler will never select this fiber again.
//   5. The NEXT fiber to resume from sched_yield performs the push_stack.
//
// This function never returns.
// =============================================================================
@no_yield
@no_mangle
pub fn fiber_exit() {
    region("fiber_exit") {
        let slot = GLOBAL_SCHED.current;
        let stack_base = GLOBAL_SCHED.fibers[slot].stack_base;

        // Flush any previously-pending reclamation BEFORE overwriting.
        // This prevents stack leaks when fibers exit back-to-back —
        // e.g., during ROF-1K drain where 1000 fibers exit consecutively.
        // Safe: we are still on OUR stack (not the pending one).
        if PENDING_RECLAIM != 0 {
            push_stack(PENDING_RECLAIM);
            PENDING_RECLAIM = 0;
        }

        // Stage OUR stack for deferred reclamation.
        // push_stack cannot be called for our own stack — we are still on it.
        PENDING_RECLAIM = stack_base;

        // Tear down the fiber from the scheduler
        GLOBAL_SCHED.fibers[slot].active = false;
        GLOBAL_SCHED.fibers[slot].stack_ptr = 0;
        GLOBAL_SCHED.fibers[slot].stack_base = 0;
        bitmap_clear(slot);
        GLOBAL_SCHED.count = GLOBAL_SCHED.count - 1;

        // Find the next runnable fiber via bitmap (inline, not via sched_yield
        // to avoid a compiler forward-reference issue in transitive compilation).
        let current_group = slot / 64;
        let current_bit = slot % 64;
        let mut next: u64 = slot;

        let l2_cur = GLOBAL_SCHED.l2_details[current_group];
        let l1 = GLOBAL_SCHED.l1_summary;

        let above = l2_cur & mask_above_bit(current_bit);
        if above != 0 {
            next = current_group * 64 + ctz_u64(above);
        } else {
            let l1_above = l1 & mask_above_bit(current_group);
            if l1_above != 0 {
                let grp = ctz_u64(l1_above);
                let l2_grp = GLOBAL_SCHED.l2_details[grp];
                next = grp * 64 + ctz_u64(l2_grp);
            } else {
                let l1_below = l1 & mask_below_bit(current_group);
                if l1_below != 0 {
                    let grp = ctz_u64(l1_below);
                    let l2_grp = GLOBAL_SCHED.l2_details[grp];
                    next = grp * 64 + ctz_u64(l2_grp);
                } else {
                    let below = l2_cur & mask_below_bit(current_bit);
                    if below != 0 {
                        next = current_group * 64 + ctz_u64(below);
                    }
                }
            }
        }

        if next != slot {
            GLOBAL_SCHED.current = next;
            let old = &GLOBAL_SCHED.fibers[slot].stack_ptr;
            let new_sp = GLOBAL_SCHED.fibers[next].stack_ptr;
            switch_stacks(old, new_sp);

            // Deferred reclamation after resuming on the live fiber's stack
            if PENDING_RECLAIM != 0 {
                push_stack(PENDING_RECLAIM);
                PENDING_RECLAIM = 0;
            }
        }
    }
}

// =============================================================================
// fiber_count — Active Fiber Count (diagnostic)
// =============================================================================
// Returns the number of live fibers. Used by slab_reclaim_bench to detect
// when all ephemeral fibers have completed.
// =============================================================================
@no_mangle
pub fn fiber_count() -> u64 {
    return GLOBAL_SCHED.count;
}

@no_yield
@no_mangle
pub fn sched_yield() {
    region("sched_yield") {
        let current = GLOBAL_SCHED.current;
        let current_group = current / 64;
        let current_bit = current % 64;

        // O(1) BITMAP SELECTION
        // Find next set bit after `current` with wraparound.
        //
        // Phase 1: Remaining bits in current group (above current_bit)
        // Phase 2: Higher groups via L1 summary
        // Phase 3: Wrap to lower groups via L1 summary
        // Phase 4: Lower bits in current group (wrap within group)

        let mut next: u64 = current;

        // Read bitmaps into locals
        let l2_cur = GLOBAL_SCHED.l2_details[current_group];
        let l1 = GLOBAL_SCHED.l1_summary;

        // Phase 1: Mask off bits <= current in the current L2 word
        let above = l2_cur & mask_above_bit(current_bit);
        if above != 0 {
            next = current_group * 64 + ctz_u64(above);
        } else {
            // Phase 2: Higher groups
            let l1_above = l1 & mask_above_bit(current_group);
            if l1_above != 0 {
                let grp = ctz_u64(l1_above);
                let l2_grp = GLOBAL_SCHED.l2_details[grp];
                next = grp * 64 + ctz_u64(l2_grp);
            } else {
                // Phase 3: Wrap to lower groups
                let l1_below = l1 & mask_below_bit(current_group);
                if l1_below != 0 {
                    let grp = ctz_u64(l1_below);
                    let l2_grp = GLOBAL_SCHED.l2_details[grp];
                    next = grp * 64 + ctz_u64(l2_grp);
                } else {
                    // Phase 4: Wrap within current group
                    let below = l2_cur & mask_below_bit(current_bit);
                    if below != 0 {
                        next = current_group * 64 + ctz_u64(below);
                    }
                    // else: no other fiber, stay on current
                }
            }
        }

        if next != current {
            GLOBAL_SCHED.current = next;
            
            let old = &GLOBAL_SCHED.fibers[current].stack_ptr;
            let new_sp = GLOBAL_SCHED.fibers[next].stack_ptr;

            switch_stacks(old, new_sp);

            // =========================================================
            // DEFERRED RECLAMATION
            // =========================================================
            // We have just resumed on a LIVE fiber's stack (after being
            // switched TO by another fiber's sched_yield). If a fiber
            // died before this switch, PENDING_RECLAIM holds its stack
            // base. We can now safely return it to the slab because we
            // are executing on OUR stack, not the dead fiber's.
            // =========================================================
            if PENDING_RECLAIM != 0 {
                push_stack(PENDING_RECLAIM);
                PENDING_RECLAIM = 0;
            }
        }
    }
}

pub fn get_id() -> u64 {
    return GLOBAL_SCHED.fibers[GLOBAL_SCHED.current].id;
}

pub fn yield_now() {
    sched_yield();
}

pub fn get_fiber_count() -> u64 {
    return fiber_count();
}

pub fn exit_fiber() {
    fiber_exit();
}
