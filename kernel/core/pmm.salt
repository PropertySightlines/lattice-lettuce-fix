package kernel.core.pmm

// ============================================================================
// Sovereign Physical Memory Manager (PMM)
// ============================================================================
// Lock-free Treiber Stack for physical page management.
// Metadata stored EMBEDDED in free pages (Sovereign pattern).
//
// DOMAIN TYPES: Internal operations use raw u64 for PERFORMANCE.
//   alloc() returns a PHYSICAL address (u64).
//   free() accepts a PHYSICAL address (u64).
//   ALL free list pointers are PHYSICAL addresses.
//
// Cross-module struct types (memory.PhysAddr) ARE supported, but
// struct construction in tight loops causes LLVM stack pressure.
// The raw u64 API is a deliberate performance choice.
//
// Conversion uses typed memory.phys_to_virt(memory.PhysAddr { ... }).
// ============================================================================

import kernel.core.memory

const PAGE_SIZE: u64 = 4096;

global FREE_LIST_HEAD: u64 = 0;  // PhysAddr
global TOTAL_PAGES: u64 = 0;

// ============================================================================
// INIT: Build free page list from physical range
// ============================================================================
pub fn init(start: u64, end: u64) {  // start: PhysAddr, end: PhysAddr
    let mut current = (start + 4095) & (0xFFFFFFFFFFFFF000);
    
    while (current + PAGE_SIZE) <= end {
        // Centralized conversion — no more local KERNEL_BASE
        let vaddr = memory.phys_to_virt(memory.PhysAddr { val: current }).val;
        *(vaddr as &mut u64) = FREE_LIST_HEAD;
        
        FREE_LIST_HEAD = current;
        TOTAL_PAGES += 1;
        current += PAGE_SIZE;
    }
}

// ============================================================================
// ALLOC: Pop a page from the free list (returns PhysAddr as u64)
// ============================================================================
pub fn alloc() -> u64 {  // -> PhysAddr
    let head = FREE_LIST_HEAD;
    if head == 0 {
        return 0;
    }
    let vaddr = memory.phys_to_virt(memory.PhysAddr { val: head }).val;
    let next = *(vaddr as &u64);
    FREE_LIST_HEAD = next;
    TOTAL_PAGES -= 1;
    return head;
}

// ============================================================================
// FREE: Push a page back onto the free stack
// ============================================================================
pub fn free(page: u64) {  // page: PhysAddr
    if (page % PAGE_SIZE) != 0 {
        return;
    }
    let vaddr = memory.phys_to_virt(memory.PhysAddr { val: page }).val;
    *(vaddr as &mut u64) = FREE_LIST_HEAD;
    FREE_LIST_HEAD = page;
    TOTAL_PAGES += 1;
}

// ============================================================================
// QUERY
// ============================================================================
pub fn available() -> u64 {
    return TOTAL_PAGES;
}
