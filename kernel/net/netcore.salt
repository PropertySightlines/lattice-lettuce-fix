// =============================================================================
// kernel/net/netcore.salt
// Network Packet Dispatcher — Demux Ethernet → ARP / IP → UDP
// =============================================================================
//
// Central packet processing loop. Called from the main kernel loop or from
// a dedicated network fiber. Polls the VirtIO-Net RX queue and dispatches
// packets through the protocol stack.
//
// Dispatch chain:
//   Ethernet → ARP (0x0806)  → arp_handle
//   Ethernet → IPv4 (0x0800) → UDP (17) → udp_handler callback
//                             → TCP (6)  → [future]
// =============================================================================

package kernel.net.netcore

import kernel.drivers.virtio_net
import kernel.drivers.serial
import kernel.net.eth
import kernel.net.arp
import kernel.net.ip
import kernel.net.udp

const VIRTIO_NET_HDR_SIZE: u32 = 10;

// =============================================================================
// UDP Callback Registration
// =============================================================================
// Simple port-based dispatch. Supports one registered handler.

global UDP_ECHO_PORT: u16 = 7;     // RFC 862 echo service
global UDP_HANDLER_PORT: u16 = 0;   // 0 = no handler registered
global UDP_PACKETS_HANDLED: u64 = 0;

// =============================================================================
// Process One RX Packet
// =============================================================================
// Returns true if a packet was processed, false if the RX queue was empty.

pub fn process_one() -> bool {
    let mut buf_addr: u64 = 0;
    let mut pkt_len: u32 = 0;

    let got = virtio_net.net_rx_poll(&mut buf_addr, &mut pkt_len);
    if !got {
        return false;
    }

    // Skip the 10-byte VirtIO header to get to the Ethernet frame
    let eth_start = buf_addr + VIRTIO_NET_HDR_SIZE as u64;
    let eth_len = pkt_len - VIRTIO_NET_HDR_SIZE;

    if eth_len < 14 {
        // Too short for an Ethernet header
        virtio_net.net_rx_repost(buf_addr);
        return true;
    }

    let eth_hdr = eth.eth_parse(eth_start, eth_len);
    let our_mac = virtio_net.get_mac();

    // Copy MAC fields into local arrays (Salt struct field access returns
    // a reference; functions expect by-value arrays)
    let mut dst_mac: [u8; 6] = [0 as u8; 6];
    let mut src_mac: [u8; 6] = [0 as u8; 6];
    let mut mi: u32 = 0;
    while mi < 6 {
        dst_mac[mi] = eth_hdr.dst[mi];
        src_mac[mi] = eth_hdr.src[mi];
        mi = mi + 1;
    }

    // Check if packet is for us (unicast match or broadcast)
    let match_us = eth.mac_matches(dst_mac, our_mac);
    let match_bc = eth.is_broadcast(dst_mac);
    if !match_us {
        if !match_bc {
            virtio_net.net_rx_repost(buf_addr);
            return true;
        }
    }

    // Dispatch by EtherType
    if eth_hdr.ethertype == 0x0806 {
        // ARP
        arp.arp_handle(eth_start, 14, eth_len, our_mac);
    }

    if eth_hdr.ethertype == 0x0800 {
        // IPv4
        let ip_start = eth_start + 14;
        let ip_len = eth_len - 14;
        handle_ipv4(ip_start, ip_len, src_mac);
    }

    // Re-post the buffer back to the RX ring
    virtio_net.net_rx_repost(buf_addr);
    return true;
}

// =============================================================================
// IPv4 Dispatch
// =============================================================================
fn handle_ipv4(buf: u64, len: u32, src_mac: [u8; 6]) {
    let ip_hdr = ip.ip_parse(buf, len);

    if ip_hdr.ihl < 20 {
        return;
    }

    // Check if destined for us
    if ip_hdr.dst_ip != 0x0A00020F {  // 10.0.2.15
        return;
    }

    let payload_offset = ip_hdr.ihl as u32;
    let payload_len = len - payload_offset;
    let payload_buf = buf + payload_offset as u64;

    if ip_hdr.protocol == 17 {
        // UDP
        handle_udp(payload_buf, payload_len, ip_hdr.src_ip, src_mac);
    }
    // Protocol 6 (TCP) and 1 (ICMP) can be added here
}

// =============================================================================
// UDP Dispatch — Echo Service
// =============================================================================
fn handle_udp(buf: u64, len: u32, src_ip: u32, src_mac: [u8; 6]) {
    let udp_hdr = udp.udp_parse(buf, len);

    if udp_hdr.dst_port == 0 {
        return;
    }

    let echo_port: u16 = 7;

    // UDP echo (port 7) or registered handler port
    if udp_hdr.dst_port == echo_port {
        // Echo the payload back to the sender
        let payload_offset: u32 = 8;  // UDP header size
        let payload_len = len - payload_offset;
        let payload_buf = buf + payload_offset as u64;

        send_udp_reply(src_ip, src_mac, udp_hdr.src_port, echo_port, payload_buf, payload_len);
        UDP_PACKETS_HANDLED = UDP_PACKETS_HANDLED + 1;

        if (UDP_PACKETS_HANDLED % 100) == 0 {
            serial.print("NET: UDP echo handled ");
            serial.print_u64(UDP_PACKETS_HANDLED);
            serial.print(" packets\n");
        }
    }
}

// =============================================================================
// Send UDP Reply
// =============================================================================
fn send_udp_reply(dst_ip: u32, dst_mac: [u8; 6], dst_port: u16, src_port: u16, payload: u64, payload_len: u32) {
    // Build frame at scratch buffer (CPU access → virtual address)
    let frame_buf: u64 = 0xFFFFFFFF80470000;
    let our_mac = virtio_net.get_mac();
    let our_ip: u32 = 0x0A00020F;

    // 1. Ethernet header (14 bytes)
    let eth_sz = eth.eth_build(frame_buf, dst_mac, our_mac, 0x0800);

    // 2. IP header (20 bytes)
    let ip_offset = eth_sz;
    let udp_total: u16 = 8 + payload_len as u16;
    let ip_sz = ip.ip_build(frame_buf + ip_offset as u64, our_ip, dst_ip, 17, udp_total);

    // 3. UDP header (8 bytes)
    let udp_offset = ip_offset + ip_sz;
    let udp_sz = udp.udp_build(frame_buf + udp_offset as u64, src_port, dst_port, payload_len as u16);

    // 4. Copy payload
    let payload_offset = udp_offset + udp_sz;
    let mut c: u32 = 0;
    while c < payload_len {
        let byte = *((payload + c as u64) as &u8);
        *((frame_buf + payload_offset as u64 + c as u64) as &mut u8) = byte;
        c = c + 1;
    }

    let total = payload_offset + payload_len;
    virtio_net.net_tx_send(frame_buf, total);
}

// =============================================================================
// Poll Loop (drain all pending RX packets)
// =============================================================================
pub fn poll_all() {
    let mut count: i32 = 0;
    while process_one() {
        count = count + 1;
        if count > 256 {
            return;  // Limit per poll cycle to avoid starving fibers
        }
    }
}

pub fn get_udp_count() -> u64 {
    return UDP_PACKETS_HANDLED;
}
