// =============================================================================
// user/netd.salt
// NetD Daemon — Network Daemon IPC Dispatcher Stub
// =============================================================================
//
// NetD is the Lattice network daemon, running as process slot 5.
// It owns the VirtIO NIC and multiplexes packet I/O to application sockets
// via shared-memory SPSC rings.
//
// Architecture:
//   Control Plane: IPC command loop handling CMD_BIND / CMD_ACCEPT / CMD_CLOSE.
//   Data Plane:    DMA from VirtIO → SPSC push to app RX ring (zero-copy path).
//                  SPSC pop from app TX ring → VirtIO TX descriptor submission.
//
// This file is the IPC dispatcher stub. The full data plane (VirtIO driver,
// DMA ring management, interrupt handling) is implemented in kernel/net/*.
// =============================================================================

package user.netd

use user.lib.syscall
use user.lib.socket_protocol

// =============================================================================
// Port Binding Table
// =============================================================================
// Simple static table: port → fd mapping. Max 16 bindings.
const MAX_BINDINGS: u64 = 16;

struct Binding {
    port: u64,      // 0 = unused slot
    fd: u64,        // File descriptor
    owner_pid: u64, // PID of the binding process
    state: u64,     // 0=free, 1=bound, 2=listening
}

const BIND_FREE: u64     = 0;
const BIND_BOUND: u64    = 1;
const BIND_LISTENING: u64 = 2;

// =============================================================================
// File Descriptor Allocation
// =============================================================================
// FDs are allocated sequentially starting from 0.
// Each FD maps to 2 pages (RX + TX) at deterministic VAADRs.

fn alloc_fd() -> u64 {
    // Static counter — next available FD
    // In production, this would be a proper allocator with free-list.
    // For the stub, we use the binding index as the FD.
    return 0;  // Placeholder — see handle_bind for actual logic
}

// =============================================================================
// VADDR Calculation
// =============================================================================
fn rx_vaddr_for_fd(fd: u64) -> u64 {
    return socket_protocol.SOCKET_VADDR_BASE + (fd * socket_protocol.SOCKET_REGION_SIZE);
}

fn tx_vaddr_for_fd(fd: u64) -> u64 {
    return socket_protocol.SOCKET_VADDR_BASE
         + (fd * socket_protocol.SOCKET_REGION_SIZE)
         + socket_protocol.SOCKET_PAGE_SIZE;
}

// =============================================================================
// Command Handlers
// =============================================================================

/// Handle CMD_BIND: Bind a port and allocate an FD.
/// Returns the FD on success, or 0xFFFFFFFFFFFFFFFF on error.
fn handle_bind(sender: u64, port: u64, bindings: u64, next_fd: &mut u64) -> u64 {
    // Check if port is already bound
    let mut i: u64 = 0;
    while i < MAX_BINDINGS {
        let slot = bindings + (i * 24);  // sizeof(Binding) = 24 bytes (3 × u64)
        let slot_port = *((slot + 0) as &u64);
        let slot_state = *((slot + 16) as &u64);
        if slot_port == port && slot_state != BIND_FREE {
            // Port in use — reply with error
            syscall.ipc_send(sender, socket_protocol.RESP_ERR, socket_protocol.ERR_PORT_IN_USE, 0);
            return 0xFFFFFFFFFFFFFFFF;
        }
        i = i + 1;
    }

    // Find free slot
    let mut slot_idx: u64 = 0;
    let mut found = false;
    i = 0;
    while i < MAX_BINDINGS {
        let slot = bindings + (i * 24);
        let slot_state = *((slot + 16) as &u64);
        if slot_state == BIND_FREE {
            slot_idx = i;
            found = true;
            i = MAX_BINDINGS; // break
        }
        i = i + 1;
    }

    if !found {
        // No free slots
        syscall.ipc_send(sender, socket_protocol.RESP_ERR, socket_protocol.ERR_NO_FDS, 0);
        return 0xFFFFFFFFFFFFFFFF;
    }

    // Allocate FD and fill slot
    let fd = *next_fd;
    *next_fd = fd + 1;

    let slot = bindings + (slot_idx * 24);
    *((slot + 0) as &mut u64) = port;
    *((slot + 8) as &mut u64) = fd;
    *((slot + 16) as &mut u64) = BIND_BOUND;

    // Reply with RESP_OK + fd
    syscall.ipc_send(sender, socket_protocol.RESP_OK, fd, 0);
    return fd;
}

/// Handle CMD_ACCEPT: Accept a connection on a bound socket.
/// For the stub: immediately grant SHM pages and reply OK.
fn handle_accept(sender: u64, fd: u64, bindings: u64) {
    // Find the binding for this FD
    let mut i: u64 = 0;
    while i < MAX_BINDINGS {
        let slot = bindings + (i * 24);
        let slot_fd = *((slot + 8) as &u64);
        let slot_state = *((slot + 16) as &u64);
        if slot_fd == fd && slot_state == BIND_BOUND {
            // Transition to LISTENING
            *((slot + 16) as &mut u64) = BIND_LISTENING;

            // Grant shared memory pages for RX and TX rings
            // NetD allocates physical pages and maps them into the caller's
            // address space at the deterministic VADDRs.
            let rx_dst = rx_vaddr_for_fd(fd);
            let tx_dst = tx_vaddr_for_fd(fd);

            // In production: allocate physical pages, init SPSC headers,
            // then call sys_shm_grant to map them into the caller's space.
            // For the stub, we use pre-allocated pages.
            // syscall.shm_grant(sender, rx_src, rx_dst, 0);
            // syscall.shm_grant(sender, tx_src, tx_dst, 0);

            // Reply OK to wake the application
            syscall.ipc_send(sender, socket_protocol.RESP_OK, fd, 0);
            return;
        }
        i = i + 1;
    }

    // FD not found
    syscall.ipc_send(sender, socket_protocol.RESP_ERR, socket_protocol.ERR_INVALID_FD, 0);
}

/// Handle CMD_CLOSE: Close a socket and release the binding.
fn handle_close(sender: u64, fd: u64, bindings: u64) {
    let mut i: u64 = 0;
    while i < MAX_BINDINGS {
        let slot = bindings + (i * 24);
        let slot_fd = *((slot + 8) as &u64);
        let slot_state = *((slot + 16) as &u64);
        if slot_fd == fd && slot_state != BIND_FREE {
            // Clear the slot
            *((slot + 0) as &mut u64) = 0;
            *((slot + 8) as &mut u64) = 0;
            *((slot + 16) as &mut u64) = BIND_FREE;

            syscall.ipc_send(sender, socket_protocol.RESP_OK, 0, 0);
            return;
        }
        i = i + 1;
    }

    syscall.ipc_send(sender, socket_protocol.RESP_ERR, socket_protocol.ERR_INVALID_FD, 0);
}

// =============================================================================
// NetD Main Loop — IPC Dispatcher
// =============================================================================
// This is the event loop that NetD runs forever.
// It blocks on ipc_recv, dispatches commands, and replies.

@no_mangle
pub fn netd_main() {
    // Allocate binding table on stack (16 × 24 = 384 bytes)
    // Each binding is 3 u64s: port, fd, state
    let mut binding_storage: [u64; 48] = [0; 48];  // 48 × 8 = 384 bytes
    let bindings = (&binding_storage) as u64;

    let mut next_fd: u64 = 0;

    // Infinite IPC dispatch loop
    loop {
        let sender = syscall.ipc_recv();

        // After ipc_recv returns:
        //   RAX = sender_pid (returned)
        //   RDI = msg0 (command)
        //   RSI = msg1 (argument)
        //   RDX = msg2 (auxiliary)
        // We need a way to read RDI/RSI/RDX after ipc_recv.
        // For now, this is a stub — the actual integration requires
        // a multi-return ABI or register-reading intrinsics.

        // Stub: the command dispatch would look like:
        // let cmd = read_rdi();
        // let arg = read_rsi();
        // match cmd {
        //     CMD_BIND   => handle_bind(sender, arg, bindings, &mut next_fd),
        //     CMD_ACCEPT => handle_accept(sender, arg, bindings),
        //     CMD_CLOSE  => handle_close(sender, arg, bindings),
        // }
    }
}
