{
    "name": "salt-language",
    "displayName": "Salt Language",
    "description": "Salt language support — syntax highlighting, diagnostics, and completions",
    "icon": "icon.png",
    "version": "0.1.1",
    "license": "MIT",
    "publisher": "salt-lang",
    "repository": {
        "type": "git",
        "url": "https://github.com/salt-lang/lattice"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "activationEvents": [
        "onLanguage:salt"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "salt",
                "aliases": [
                    "Salt",
                    "salt"
                ],
                "extensions": [
                    ".salt"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "salt",
                "scopeName": "source.salt",
                "path": "./syntaxes/salt.tmLanguage.json"
            }
        ]
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/node": "^25.2.3",
        "@types/vscode": "^1.85.0",
        "typescript": "^5.3.0"
    }
}