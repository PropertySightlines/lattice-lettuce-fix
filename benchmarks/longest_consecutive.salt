// longest_consecutive.salt - LeetCode 128: Longest Consecutive Sequence

package main

use std.core.ptr.Ptr
use std.core.arena

use std.collections.hash_map.HashMap

fn main() -> i32 {
    let mut total: i64 = 0;
    let n: i64 = 100000;
    let nums = arena::alloc(n * 8) as Ptr<i64>;
    
    for round in 0..100 {
        for i in 0..n {
            nums[i] = (i * 1103515245 + 12345 + round) % (n * 10);
        }
        
        let mut set = HashMap<i64, i64>::with_capacity(n);
        for i in 0..n {
            set.insert(nums[i], 1);
        }
        
        let mut best: i64 = 0;
        for i in 0..n {
            let num = nums[i];
            let key_prev = num - 1;
            if set.get(key_prev) == 0 {
                let mut len: i64 = 1;
                let mut key_next = num + len;
                while set.get(key_next) != 0 {
                    len += 1;
                    key_next = num + len;
                }
                if len > best { best = len; }
            }
        }
        
        set.drop();
        total += best;
    }
    
    println(f"Total: {total}");
    return 0;
}
