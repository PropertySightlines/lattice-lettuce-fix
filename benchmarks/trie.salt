// LeetCode 208: Implement Trie (Prefix Tree)
package main

use std.core.ptr.Ptr
use std.core.arena

struct TrieNode {
    children: [Ptr<TrieNode>; 26],
    is_word: u8
}

fn create_node() -> Ptr<TrieNode> {
    let node = arena::alloc(216) as Ptr<TrieNode>;
    for i in 0..26 {
        node.children[i as i64] = Ptr::empty();
    }
    node.is_word = 0;
    return node;
}

fn insert(root: Ptr<TrieNode>, word: Ptr<u8>, len: i64) {
    let mut curr = root;
    for i in 0..len {
        let idx = (word[i] as i32) - 97;
        let child = curr.children[idx as i64];
        if child {
            curr = child;
        } else {
            let new_child = create_node();
            curr.children[idx as i64] = new_child;
            curr = new_child;
        }
    }
    curr.is_word = 1;
}

fn search(root: Ptr<TrieNode>, word: Ptr<u8>, len: i64) -> bool {
    if root {
        let mut curr = root;
        for i in 0..len {
            let idx = (word[i] as i32) - 97;
            let child = curr.children[idx as i64];
            if child {
                curr = child;
            } else {
                return false;
            }
        }
        return curr.is_word != 0;
    }
    return false;
}

fn fill_word(word: Ptr<u8>, i: i32) {
    word[0 as i64] = ((i % 26) + 97) as u8;
    word[1 as i64] = (((i / 26) % 26) + 97) as u8;
    word[2 as i64] = (((i / 676) % 26) + 97) as u8;
    word[3 as i64] = (((i / 17576) % 26) + 97) as u8;
    word[4 as i64] = ((i % 7) + 97) as u8;
}

fn main() -> i32 {
    let root = create_node();
    let word: [u8; 6];

    for i in 0..700000 {
        fill_word(word as Ptr<u8>, i);
        insert(root, word as Ptr<u8>, 5);
    }

    println("Searching 700k words...");
    let mut found = 0;
    for i in 0..700000 {
        fill_word(word as Ptr<u8>, i);
        if search(root, word as Ptr<u8>, 5) { found += 1; }
    }

    println(f"Found: {found as i64}");
    return 0;
}
