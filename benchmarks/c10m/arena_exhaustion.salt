// C10M Benchmark: Arena Exhaustion
// Tests memory resilience under high work-stealing rates
//
// Target Metrics:
//   - Linear scaling across all cores
//   - No contention cliff from false sharing
//   - Delayed Free Mailbox handles cross-thread returns
//
// [SOVEREIGN V2.0] Stresses the Sovereign Arena + Mailbox

package benchmarks.c10m.arena_exhaustion

use std.core.sovereign.context
use std.core.sovereign.executor
use std.core.sovereign.arena
use std.io

// ============================================================================
// Configuration
// ============================================================================

const NUM_TASKS: i64 = 10_000_000;
const FRAME_SIZES: [i64; 4] = [64, 256, 512, 4096]; // Varying task frame sizes
const NUM_THREADS: i64 = 8;

// Statistics
static TASKS_COMPLETED: i64 = 0;
static FRAMES_ALLOCATED: i64 = 0;
static FRAMES_FREED: i64 = 0;
static CROSS_THREAD_RETURNS: i64 = 0;

// ============================================================================
// Task Factory - Creates tasks with varying frame sizes
// ============================================================================

// A task that allocates a frame of the given size, does some work,
// then completes. Under work stealing, the completion may happen
// on a different thread than allocation.
fn create_task_with_frame(size_tier: i64) {
    let size = FRAME_SIZES[size_tier % 4];
    
    // Allocate from thread-local arena
    let frame_ptr = arena::alloc_frame(size);
    FRAMES_ALLOCATED = FRAMES_ALLOCATED + 1;
    
    // Simulate work - write to the frame
    let ptr_as_i64 = frame_ptr as Ptr<i64>;
    for i in 0..(size / 8) {
        ptr_as_i64.offset(i).write(i * 7);
    }
    
    // Verify the writes (prevents DCE)
    let sum: i64 = 0;
    for i in 0..(size / 8) {
        sum = sum + ptr_as_i64.offset(i).read();
    }
    
    // Task completes - frame is freed
    // If this thread != allocating thread, goes to Delayed Free Mailbox
    let freed_cross_thread = arena::free_frame(frame_ptr, size);
    FRAMES_FREED = FRAMES_FREED + 1;
    if freed_cross_thread {
        CROSS_THREAD_RETURNS = CROSS_THREAD_RETURNS + 1;
    }
    
    TASKS_COMPLETED = TASKS_COMPLETED + 1;
    
    // Prevent DCE
    if sum == 0 {
        io::println("Unexpected: zero sum");
    }
}

// ============================================================================
// Work Stealing Stress Test
// ============================================================================

@pulse(1000Hz)
fn task_spawner() {
    // Spawn tasks in bursts to encourage work stealing
    for i in 0..1000 {
        let size_tier = i % 4;
        executor::spawn(create_task_with_frame, size_tier);
    }
}

// ============================================================================
// Benchmark Harness
// ============================================================================

pub fn main(argc: i32, argv: Ptr<Ptr<u8>>) -> i32 {
    io::println("=== C10M Arena Exhaustion Benchmark ===");
    io::println(f"Tasks: {NUM_TASKS}");
    io::println(f"Threads: {NUM_THREADS}");
    io::println(f"Frame sizes: 64B, 256B, 512B, 4KB");
    io::println("");
    
    // Initialize executor
    executor::init(NUM_THREADS);
    
    // Initialize arena with tiered slabs
    arena::init_tiered();
    
    let start = intrinsics::cycle_counter();
    
    // Spawn task spawners on each thread
    for t in 0..NUM_THREADS {
        executor::spawn_pulse_on_thread(task_spawner, 1000, t);
    }
    
    // Run until all tasks complete
    while TASKS_COMPLETED < NUM_TASKS {
        executor::tick();
        
        // Log progress every 1M tasks
        if TASKS_COMPLETED % 1_000_000 == 0 && TASKS_COMPLETED > 0 {
            io::println(f"Progress: {TASKS_COMPLETED / 1_000_000}M / {NUM_TASKS / 1_000_000}M");
        }
    }
    
    let end = intrinsics::cycle_counter();
    let elapsed_ms = (end - start) / 4_000_000;
    
    executor::shutdown();
    
    // Report results
    io::println("");
    io::println("=== Results ===");
    io::println(f"Total time: {elapsed_ms}ms");
    io::println(f"Tasks completed: {TASKS_COMPLETED}");
    io::println(f"Frames allocated: {FRAMES_ALLOCATED}");
    io::println(f"Frames freed: {FRAMES_FREED}");
    io::println(f"Cross-thread returns: {CROSS_THREAD_RETURNS}");
    io::println(f"Throughput: {TASKS_COMPLETED * 1000 / elapsed_ms} tasks/s");
    
    // Calculate work stealing rate
    let steal_rate = (CROSS_THREAD_RETURNS * 100) / FRAMES_FREED;
    io::println(f"Work stealing rate: {steal_rate}%%");
    
    // Verify no memory leaks
    let arena_stats = arena::stats();
    io::println(f"Arena overhead: {arena_stats.total_allocated - arena_stats.total_freed} bytes");
    
    if arena_stats.total_allocated == arena_stats.total_freed {
        io::println("✅ PASS: No memory leaks");
        return 0;
    } else {
        io::println("❌ FAIL: Memory leak detected");
        return 1;
    }
}
