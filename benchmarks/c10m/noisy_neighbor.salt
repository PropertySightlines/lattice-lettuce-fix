// C10M Benchmark: Noisy Neighbor
// Tests scheduler fairness - 1000Hz real-time pulse vs 60Hz heavy compute
//
// Target Metrics:
//   - 1000Hz pulse jitter < 1ms (must never miss a beat)
//   - Heavy 60Hz tasks cannot starve the real-time pulse
//   - Proves yield point injection works at back-edges
//
// [SOVEREIGN V2.0] Multi-pulse scheduling with shared state

package benchmarks.c10m.noisy_neighbor

use std.core.sovereign.context
use std.core.sovereign.executor
use std.collections.hash_map
use std.sync.mutex
use std.io

// ============================================================================
// Shared State - Accessed by both pulses
// ============================================================================

struct SensorData {
    timestamp: i64,
    gyro_x: f32,
    gyro_y: f32,
    gyro_z: f32,
}

// Ring buffer for sensor data (1024 samples)
struct RingBuffer {
    data: [SensorData; 1024],
    head: i64,
    tail: i64,
    count: i64,
}

impl RingBuffer {
    pub fn new() -> RingBuffer {
        return RingBuffer {
            data: [SensorData { timestamp: 0, gyro_x: 0.0, gyro_y: 0.0, gyro_z: 0.0 }; 1024],
            head: 0,
            tail: 0,
            count: 0,
        };
    }
    
    pub fn push(self: &mut RingBuffer, item: SensorData) {
        self.data[self.head] = item;
        self.head = (self.head + 1) % 1024;
        if self.count < 1024 {
            self.count = self.count + 1;
        } else {
            self.tail = (self.tail + 1) % 1024;
        }
    }
    
    pub fn drain(self: &mut RingBuffer) -> i64 {
        let drained = self.count;
        self.count = 0;
        self.head = 0;
        self.tail = 0;
        return drained;
    }
}

// Global shared buffer protected by mutex
static SHARED_BUFFER: Mutex<RingBuffer> = Mutex::new(RingBuffer::new());

// Jitter tracking for 1000Hz pulse
static LAST_SENSOR_TICK: i64 = 0;
static MAX_JITTER_US: i64 = 0;
static SENSOR_TICK_COUNT: i64 = 0;

// ============================================================================
// Tier 0: Real-Time Sensor Pulse (1000Hz)
// ============================================================================

// @pulse(1000Hz) marks this as a Tier 0 (Real-Time) function
// - Pinned to performance cores
// - Pre-empts Tier 1 tasks immediately
// - Context carries a 1ms deadline budget
@pulse(1000Hz)
fn sensor_ingest() {
    let now = intrinsics::cycle_counter();
    
    // Track jitter
    if LAST_SENSOR_TICK > 0 {
        let delta_cycles = now - LAST_SENSOR_TICK;
        // At 4GHz, 1ms = 4M cycles
        let expected_cycles: i64 = 4_000_000;
        let jitter_cycles = if delta_cycles > expected_cycles {
            delta_cycles - expected_cycles
        } else {
            expected_cycles - delta_cycles
        };
        let jitter_us = jitter_cycles / 4000; // cycles to microseconds
        
        if jitter_us > MAX_JITTER_US {
            MAX_JITTER_US = jitter_us;
        }
    }
    LAST_SENSOR_TICK = now;
    SENSOR_TICK_COUNT = SENSOR_TICK_COUNT + 1;
    
    // Simulate sensor read (fast - no yield needed)
    let data = SensorData {
        timestamp: now,
        gyro_x: pseudo_random_f32(now),
        gyro_y: pseudo_random_f32(now + 1),
        gyro_z: pseudo_random_f32(now + 2),
    };
    
    // Push to shared buffer (mutex acquire is a yield point)
    SHARED_BUFFER.lock().push(data);
}

// ============================================================================
// Tier 1: Heavy Compute Pulse (60Hz) - The "Noisy Neighbor"
// ============================================================================

// @pulse(60Hz) marks this as a Tier 1 (Interactive) function
// - Can be pre-empted by Tier 0 tasks
// - 16.67ms deadline budget
// - Yield points injected at loop back-edges
@pulse(60Hz)
fn heavy_compute() {
    // Create a large HashMap for stress testing
    let map: HashMap<i64, i64> = HashMap::new();
    
    // Insert 100K entries
    for i in 0..100_000 {
        // Back-edge: compiler injects ctx.check_deadline() here
        // If a 1000Hz pulse is waiting, we yield immediately
        map.insert(i, i * 2);
    }
    
    // Perform 5M lookups (the "heavy" part)
    let sum: i64 = 0;
    for i in 0..5_000_000 {
        // Back-edge: another yield check
        let key = i % 100_000;
        match map.get(&key) {
            Some(val) => { sum = sum + *val; }
            None => {}
        }
    }
    
    // Drain sensor buffer and "process" the data
    let drained = SHARED_BUFFER.lock().drain();
    
    // Prevent DCE
    if sum == 0 && drained == 0 {
        io::println("Unexpected: no data processed");
    }
}

// ============================================================================
// Helpers
// ============================================================================

fn pseudo_random_f32(seed: i64) -> f32 {
    let x = seed ^ (seed >> 21);
    let x = x ^ (x << 35);
    let x = x ^ (x >> 4);
    return (x % 1000) as f32 / 1000.0;
}

// ============================================================================
// Benchmark Harness
// ============================================================================

const BENCHMARK_DURATION_SECONDS: i64 = 10;

pub fn main(argc: i32, argv: Ptr<Ptr<u8>>) -> i32 {
    io::println("=== C10M Noisy Neighbor Benchmark ===");
    io::println("Testing: 1000Hz sensor vs 60Hz heavy compute");
    io::println(f"Duration: {BENCHMARK_DURATION_SECONDS} seconds");
    io::println("");
    
    // Initialize executor with 4 cores (typical M4 performance cores)
    executor::init(4);
    
    // Spawn both pulses - they will run concurrently
    executor::spawn_pulse(sensor_ingest, 1000);  // 1000Hz, Tier 0
    executor::spawn_pulse(heavy_compute, 60);    // 60Hz, Tier 1
    
    // Run for benchmark duration
    let start = intrinsics::cycle_counter();
    let end_target = start + (BENCHMARK_DURATION_SECONDS * 4_000_000_000); // 4GHz
    
    while intrinsics::cycle_counter() < end_target {
        executor::tick(); // Process one round of tasks
    }
    
    executor::shutdown();
    
    // Report results
    io::println("=== Results ===");
    io::println(f"Sensor ticks: {SENSOR_TICK_COUNT}");
    io::println(f"Expected ticks: {BENCHMARK_DURATION_SECONDS * 1000}");
    io::println(f"Max jitter: {MAX_JITTER_US}μs");
    
    // Success criteria: jitter < 1000μs (1ms)
    if MAX_JITTER_US < 1000 {
        io::println("✅ PASS: Jitter within 1ms tolerance");
        return 0;
    } else {
        io::println("❌ FAIL: Jitter exceeded 1ms");
        return 1;
    }
}
