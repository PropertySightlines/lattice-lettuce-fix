// CODE RED: Out-of-Bounds Hijack Diagnostic
// This file MUST fail to compile if the Z3 Formal Shadow is working correctly.
//
// The Z3 slice verifier should detect that view[10000] is unsafe
// when 'end' comes from find_header_end (could be as small as 4).
//
// Expected Compiler Output:
//   [CODE RED] Formal Verification Failure
//   File: out_of_bounds_hijack.salt (Line ~22)
//   Operation: view[10000]
//   Violation: Potential memory corruption detected.
//   Z3 Analysis: end is dynamically bounded by find_header_end (≤ 16384).
//                Solver found a state where end < 10000.
//
// If this compiles successfully, the Citadel has been breached.

package benchmarks.c10m.out_of_bounds_hijack

struct SovereignBuffer {
    data: Ptr<u8>,
    capacity: i64,
    length: i64,
    offset: i64,
}

@pulse
fn dangerous_handler(buf: SovereignBuffer) {
    // 1. SIMD finds the end of the headers
    // Returns dynamically: could be 4 (\r\n\r\n min) or up to buf.length
    let end = find_header_end_simd(buf.data, buf.length);

    if end == -1 {
        yield;  // Suspend for more data
    }

    // 2. Create a zero-copy view of the headers
    let view = buf.slice(0, end);

    // 3. CODE RED: Intentional out-of-bounds access
    // 'end' could be as small as 4.
    // 'view[10000]' attempts to read 10000 bytes past the start.
    //
    // Z3 Logic:
    //   Assert: 0 <= start=0, start <= end, end <= 16384
    //   Violation: start + 10000 >= end
    //   Result: SAT (counterexample: end=4, 10000 >= 4)
    //   Action: HALT COMPILATION
    let illegal_data = view[10000];

    // This line should NEVER be reached at compile time
    println("If you see this, the Citadel is breached: {}", illegal_data);
}

// Simulated SIMD header scanner (returns byte offset of \r\n\r\n)
fn find_header_end_simd(data: Ptr<u8>, length: i64) -> i64 {
    let mut cursor: i64 = 0;
    while cursor < length - 3 {
        if data.read_at(cursor) == 13 &&
           data.read_at(cursor + 1) == 10 &&
           data.read_at(cursor + 2) == 13 &&
           data.read_at(cursor + 3) == 10 {
            return cursor + 4;
        }
        cursor = cursor + 1;
    }
    return -1;
}

fn main() -> i32 {
    println("=== CODE RED: This should NOT compile ===");
    let buf = SovereignBuffer {
        data: 0 as Ptr<u8>,
        capacity: 16384,
        length: 128,
        offset: 0,
    };
    dangerous_handler(buf);
    return 0;
}
