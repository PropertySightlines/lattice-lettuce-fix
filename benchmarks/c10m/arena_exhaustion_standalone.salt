// C10M Benchmark: Arena Exhaustion (Simplified Salt Version)
// Tests tiered slab allocation performance without full runtime
//
// This is a self-contained version that can compile and run now.

use std::collections::vec::Vec

// Constants matching C/Rust baselines
const SLAB_64_COUNT: i64 = 8192
const SLAB_512_COUNT: i64 = 2048
const WORK_STEALING_ROUNDS: i64 = 1000000
const WORKERS: i64 = 4

// Bitmap-based slab allocator
struct TieredArena {
    // Using Vec<u8> to represent slab storage
    slab_64: Vec<u8>,
    slab_512: Vec<u8>,
    // Bitmap: 1 = free, 0 = allocated
    bitmap_64: Vec<i64>,
    bitmap_512: Vec<i64>,
    alloc_count_64: i64,
    alloc_count_512: i64,
    free_count: i64,
}

impl TieredArena {
    fn new() -> TieredArena {
        let mut arena = TieredArena {
            slab_64: Vec<u8>::new(),
            slab_512: Vec<u8>::new(),
            bitmap_64: Vec<i64>::new(),
            bitmap_512: Vec<i64>::new(),
            alloc_count_64: 0,
            alloc_count_512: 0,
            free_count: 0,
        }
        
        // Initialize bitmap entries (all 1s = all free)
        for i in 0..(SLAB_64_COUNT / 64) {
            arena.bitmap_64.push(-1)  // All bits set = 0xFFFFFFFFFFFFFFFF
        }
        for i in 0..(SLAB_512_COUNT / 64) {
            arena.bitmap_512.push(-1)
        }
        
        arena
    }
    
    fn alloc_64(self: &mut TieredArena) -> i64 {
        for i in 0..(SLAB_64_COUNT / 64) {
            let bitmap_val = self.bitmap_64.get(i)
            if bitmap_val != 0 {
                // Find first set bit (ctz simulation)
                let bit = count_trailing_zeros(bitmap_val)
                // Clear the bit
                self.bitmap_64.set(i, bitmap_val & !(1 << bit))
                self.alloc_count_64 = self.alloc_count_64 + 1
                return i * 64 + bit
            }
        }
        return -1  // Allocation failed
    }
    
    fn alloc_512(self: &mut TieredArena) -> i64 {
        for i in 0..(SLAB_512_COUNT / 64) {
            let bitmap_val = self.bitmap_512.get(i)
            if bitmap_val != 0 {
                let bit = count_trailing_zeros(bitmap_val)
                self.bitmap_512.set(i, bitmap_val & !(1 << bit))
                self.alloc_count_512 = self.alloc_count_512 + 1
                return i * 64 + bit
            }
        }
        return -1
    }
    
    fn free_64(self: &mut TieredArena, idx: i64) {
        if idx >= 0 && idx < SLAB_64_COUNT {
            let bitmap_idx = idx / 64
            let bit = idx % 64
            let old_val = self.bitmap_64.get(bitmap_idx)
            self.bitmap_64.set(bitmap_idx, old_val | (1 << bit))
            self.free_count = self.free_count + 1
        }
    }
    
    fn free_512(self: &mut TieredArena, idx: i64) {
        if idx >= 0 && idx < SLAB_512_COUNT {
            let bitmap_idx = idx / 64
            let bit = idx % 64
            let old_val = self.bitmap_512.get(bitmap_idx)
            self.bitmap_512.set(bitmap_idx, old_val | (1 << bit))
            self.free_count = self.free_count + 1
        }
    }
    
    fn total_allocs(self: &TieredArena) -> i64 {
        self.alloc_count_64 + self.alloc_count_512
    }
}

// Count trailing zeros - bit twiddling
fn count_trailing_zeros(x: i64) -> i64 {
    if x == 0 { return 64 }
    let mut count: i64 = 0
    let mut val = x
    while (val & 1) == 0 {
        count = count + 1
        val = val >> 1
    }
    count
}

// Simulate work stealing round
fn work_stealing_simulation(arena: &mut TieredArena, worker_id: i64) {
    let mut frames_64: [i64; 32] = [0; 32]
    let mut frames_512: [i64; 16] = [0; 16]
    let mut count_64: i64 = 0
    let mut count_512: i64 = 0
    
    // Allocate 64B frames
    for i in 0..32 {
        let idx = arena.alloc_64()
        if idx >= 0 {
            frames_64[count_64] = idx
            count_64 = count_64 + 1
        }
    }
    
    // Allocate 512B frames
    for i in 0..16 {
        let idx = arena.alloc_512()
        if idx >= 0 {
            frames_512[count_512] = idx
            count_512 = count_512 + 1
        }
    }
    
    // Free all frames back
    for i in 0..count_64 {
        arena.free_64(frames_64[i])
    }
    for i in 0..count_512 {
        arena.free_512(frames_512[i])
    }
}

// External timing function
extern fn rdtsc() -> i64

fn main() -> i32 {
    println("=== C10M Arena Exhaustion Benchmark (Salt) ===")
    println("Testing: Tiered slab allocation under work stealing")
    println("Workers: 4, Rounds: 1000000")
    println("")
    
    // Create per-worker arenas
    let mut arena0 = TieredArena::new()
    let mut arena1 = TieredArena::new()
    let mut arena2 = TieredArena::new()
    let mut arena3 = TieredArena::new()
    
    let start_ns = rdtsc()
    
    // Simulate work stealing rounds
    for round in 0..WORK_STEALING_ROUNDS {
        work_stealing_simulation(&mut arena0, 0)
        work_stealing_simulation(&mut arena1, 1)
        work_stealing_simulation(&mut arena2, 2)
        work_stealing_simulation(&mut arena3, 3)
    }
    
    let elapsed_ns = rdtsc() - start_ns
    
    // Aggregate stats
    let total_allocs = arena0.total_allocs() + arena1.total_allocs() + 
                       arena2.total_allocs() + arena3.total_allocs()
    let total_frees = arena0.free_count + arena1.free_count + 
                      arena2.free_count + arena3.free_count
    
    let elapsed_ms = elapsed_ns / 1000000
    let allocs_per_sec = if elapsed_ms > 0 { total_allocs * 1000 / elapsed_ms } else { 0 }
    let ns_per_alloc = if total_allocs > 0 { elapsed_ns / total_allocs } else { 0 }
    
    println("=== Results ===")
    println("Total allocations: {}", total_allocs)
    println("Total frees: {}", total_frees)
    println("Time: {}ms", elapsed_ms)
    println("Allocs/second: {}", allocs_per_sec)
    println("ns/alloc: {}", ns_per_alloc)
    
    // Pass if < 50ns per allocation
    if ns_per_alloc < 50 {
        println("PASS: Allocation overhead acceptable")
        0
    } else {
        println("WARN: Allocation overhead high (target: <50ns)")
        1
    }
}
