// =============================================================================
// C10M Echo Server — Salt (Compilable via existing pipeline)
//
// Uses extern fn declarations to bind directly to socket/kqueue C functions.
// Built via: salt-front → MLIR → mlir-opt → mlir-translate → clang + bridge
//
// This version uses ONLY proven Salt features:
//   - extern fn for FFI
//   - while loops (not bare loop{})
//   - No std.net, no @pulse, no yield
// =============================================================================

package main

// Socket/IO extern declarations (implemented in echo_salt_bridge.c)
extern fn echo_server_init(port: i32) -> i32;
extern fn echo_kq_create(listen_fd: i32) -> i32;
extern fn echo_kq_poll(kq: i32, listen_fd: i32, buf: u64, buf_len: i64) -> i64;

// Timing
extern fn rdtsc() -> i64;

// Memory
extern fn malloc(size: i64) -> u64;

const PORT: i32 = 8080;
const BUF_SIZE: i64 = 4096;

fn main() -> i32 {
    println("=== Salt Echo Server (port 8080) ===");
    
    // Setup: socket + bind + listen
    let listen_fd = echo_server_init(PORT);
    if listen_fd < 0 {
        println("ERROR: server init failed");
        return 1;
    }
    
    // Create kqueue and register listener
    let kq = echo_kq_create(listen_fd);
    if kq < 0 {
        println("ERROR: kqueue init failed");
        return 1;
    }
    
    // Allocate echo buffer
    let buf = malloc(BUF_SIZE);
    
    println("[Salt/kqueue] Echo server listening on port 8080");
    
    // Event loop: poll returns bytes echoed (or 0 for accept, -1 for error)
    let mut total_bytes: i64 = 0;
    while true {
        let n = echo_kq_poll(kq, listen_fd, buf, BUF_SIZE);
        if n > 0 {
            total_bytes = total_bytes + n;
        }
    }
    
    return 0;
}
