// C10M Benchmark: Echo Chamber
// Tests throughput and latency with 10M concurrent TCP connections
//
// Target Metrics:
//   - P99 latency < 100μs at 1M echoes/second
//   - Memory < 1.2KB per connection
//   - Linear scaling across cores
//
// [SOVEREIGN V2.0] Uses @pulse for cooperative scheduling

package benchmarks.c10m.echo_chamber

use std.core.sovereign.context
use std.core.sovereign.executor
use std.io
use std.net

// ============================================================================
// Configuration
// ============================================================================

const PORT: u16 = 8080;
const BUFFER_SIZE: i64 = 1024;
const TARGET_CONNECTIONS: i64 = 10_000_000;

// ============================================================================
// Echo Server - Uses @pulse for cooperative I/O scheduling
// ============================================================================

// The @pulse(1000Hz) attribute:
// 1. Auto-injects a hidden Context parameter (ZST)
// 2. Sets a 1ms deadline budget for this function
// 3. Compiler inserts yield checks at I/O points
@pulse(1000Hz)
pub fn tcp_echo_server(port: u16) {
    let listener = net::TcpListener::bind("0.0.0.0", port);
    
    io::println(f"[Echo Server] Listening on port {port}");
    io::println(f"[Echo Server] Target: {TARGET_CONNECTIONS} connections");
    
    let connection_count: i64 = 0;
    
    // The accept() call implicitly uses the injected Context
    // If we miss the deadline, the executor pre-empts us
    while connection_count < TARGET_CONNECTIONS {
        match listener.accept() {
            Ok(stream) => {
                connection_count = connection_count + 1;
                // Spawn a child Salt-let for each connection
                // The child inherits a fresh Context with its own deadline
                executor::spawn(handle_connection, stream);
            }
            Err(e) => {
                io::println(f"[Echo Server] Accept error: {e}");
            }
        }
    }
    
    io::println(f"[Echo Server] Handled {connection_count} connections");
}

// Connection handler - inherits Context from parent
// No @pulse needed - the executor provides the Context
fn handle_connection(mut stream: net::TcpStream) {
    let buf: [u8; 1024] = [0; 1024];
    
    loop {
        // read() is a yield point - checks deadline before blocking
        let n = stream.read(&mut buf);
        
        if n == 0 {
            // Connection closed
            break;
        }
        
        if n < 0 {
            // Error
            break;
        }
        
        // Echo back
        stream.write(&buf[0..n]);
    }
    
    stream.close();
}

// ============================================================================
// Benchmark Harness
// ============================================================================

pub fn main(argc: i32, argv: Ptr<Ptr<u8>>) -> i32 {
    io::println("=== C10M Echo Chamber Benchmark ===");
    io::println("");
    
    // Start timing
    let start = intrinsics::cycle_counter();
    
    // Initialize the Sovereign Executor with 8 worker threads
    executor::init(8);
    
    // Start the echo server on the main pulse
    executor::spawn_pulse(tcp_echo_server, PORT, 1000); // 1000Hz
    
    // Run until all connections handled
    executor::run_until_complete();
    
    // Stop timing
    let end = intrinsics::cycle_counter();
    let elapsed_cycles = end - start;
    
    // M4 runs at ~4GHz, so cycles/4B = seconds
    let elapsed_ms = elapsed_cycles / 4_000_000;
    
    io::println(f"=== Results ===");
    io::println(f"Total time: {elapsed_ms}ms");
    io::println(f"Connections: {TARGET_CONNECTIONS}");
    io::println(f"Throughput: {TARGET_CONNECTIONS * 1000 / elapsed_ms} conn/s");
    
    return 0;
}
