// C10M Benchmark: Noisy Neighbor (Simplified Salt Version)
// Tests scheduler fairness - simulates 1000Hz vs 60Hz interleaved work
//
// Self-contained version without full sovereign runtime.

use std::collections::hash_map::HashMap

// Constants matching C/Rust baselines
const RING_BUFFER_SIZE: i64 = 1024
const BENCHMARK_DURATION_MS: i64 = 5000
const HASHMAP_SIZE: i64 = 100000
const LOOKUPS_PER_FRAME: i64 = 5000000

struct SensorData {
    timestamp: i64,
    gyro_x: f32,
    gyro_y: f32,
    gyro_z: f32,
}

struct RingBuffer {
    data: [SensorData; 1024],
    head: i64,
    tail: i64,
    count: i64,
}

impl RingBuffer {
    fn new() -> RingBuffer {
        RingBuffer {
            data: [SensorData { timestamp: 0, gyro_x: 0.0, gyro_y: 0.0, gyro_z: 0.0 }; 1024],
            head: 0,
            tail: 0,
            count: 0,
        }
    }
    
    fn push(self: &mut RingBuffer, item: SensorData) {
        self.data[self.head] = item
        self.head = (self.head + 1) % RING_BUFFER_SIZE
        if self.count < RING_BUFFER_SIZE {
            self.count = self.count + 1
        } else {
            self.tail = (self.tail + 1) % RING_BUFFER_SIZE
        }
    }
    
    fn drain(self: &mut RingBuffer) -> i64 {
        let drained = self.count
        self.count = 0
        self.head = 0
        self.tail = 0
        drained
    }
}

fn pseudo_random_f32(seed: i64) -> f32 {
    let x = seed ^ (seed >> 21)
    let x = x ^ (x << 35)
    let x = x ^ (x >> 4)
    (x % 1000) as f32 / 1000.0
}

// External timing function
extern fn rdtsc() -> i64

fn main() -> i32 {
    println("=== C10M Noisy Neighbor Benchmark (Salt) ===")
    println("Testing: 1000Hz sensor vs 60Hz heavy compute")
    println("Duration: {} ms", BENCHMARK_DURATION_MS)
    println("")
    
    // Pre-create hashmap with data
    let mut map: HashMap<i64, i64> = HashMap::new()
    for i in 0..HASHMAP_SIZE {
        map.insert(i, i * 2)
    }
    
    let mut buffer = RingBuffer::new()
    let mut max_jitter_us: i64 = 0
    let mut sensor_tick_count: i64 = 0
    let mut last_sensor_ns: i64 = 0
    
    let start_ns = rdtsc()
    let duration_ns = BENCHMARK_DURATION_MS * 1000000
    
    let mut next_sensor_ns: i64 = 0
    let mut next_compute_ns: i64 = 0
    let sensor_interval_ns: i64 = 1000000      // 1ms for 1000Hz
    let compute_interval_ns: i64 = 16666666    // ~16.67ms for 60Hz
    
    let mut compute_sum: i64 = 0
    let mut compute_frames: i64 = 0
    
    // Main loop - interleave sensor and compute
    while true {
        let now = rdtsc() - start_ns
        if now >= duration_ns { break }
        
        // Sensor task (higher priority)
        if now >= next_sensor_ns {
            if last_sensor_ns > 0 {
                let delta_ns = now - last_sensor_ns
                let expected_ns: i64 = 1000000
                let jitter_ns = if delta_ns > expected_ns {
                    delta_ns - expected_ns
                } else {
                    expected_ns - delta_ns
                }
                let jitter_us = jitter_ns / 1000
                if jitter_us > max_jitter_us {
                    max_jitter_us = jitter_us
                }
            }
            last_sensor_ns = now
            sensor_tick_count = sensor_tick_count + 1
            
            let data = SensorData {
                timestamp: now,
                gyro_x: pseudo_random_f32(now),
                gyro_y: pseudo_random_f32(now + 1),
                gyro_z: pseudo_random_f32(now + 2),
            }
            buffer.push(data)
            next_sensor_ns = next_sensor_ns + sensor_interval_ns
        }
        
        // Compute task
        if now >= next_compute_ns {
            let mut sum: i64 = 0
            for i in 0..LOOKUPS_PER_FRAME {
                let key = i % HASHMAP_SIZE
                match map.get(&key) {
                    Some(val) => { sum = sum + *val }
                    None => {}
                }
            }
            
            let drained = buffer.drain()
            compute_sum = compute_sum + sum + drained
            compute_frames = compute_frames + 1
            next_compute_ns = next_compute_ns + compute_interval_ns
        }
    }
    
    let elapsed_ns = rdtsc() - start_ns
    let elapsed_ms = elapsed_ns / 1000000
    
    println("=== Results ===")
    println("Sensor ticks: {}", sensor_tick_count)
    println("Expected ticks: ~{}", BENCHMARK_DURATION_MS)
    println("Compute frames: {} (expected: ~{})", compute_frames, BENCHMARK_DURATION_MS / 16)
    println("Max jitter: {}us", max_jitter_us)
    println("Total time: {}ms", elapsed_ms)
    
    // Prevent DCE
    if compute_sum == 0 {
        println("Unexpected zero sum")
    }
    
    // Success criteria: jitter < 1000μs (1ms)
    if max_jitter_us < 1000 {
        println("PASS: Jitter within 1ms tolerance")
        0
    } else {
        println("FAIL: Jitter exceeded 1ms")
        1
    }
}
