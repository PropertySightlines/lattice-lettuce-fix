package main

use std.time.Instant

struct Board { cells: [u8; 81] }

// Status codes (enum MLIR lowering not implemented yet)
const STATUS_FOUND: i32 = 1;
const STATUS_UNSOLVABLE: i32 = 0;

fn is_valid(b: &Board, r: i32, c: i32, n: u8) -> bool {
    for i in 0..9 {
        if b.cells[(r * 9 + i) as usize] == n || b.cells[(i * 9 + c) as usize] == n { return false; }
    }
    let (sr, sc) = ((r / 3) * 3, (c / 3) * 3);
    for i in 0..3 {
        for j in 0..3 {
            if b.cells[((sr + i) * 9 + (sc + j)) as usize] == n { return false; }
        }
    }
    return true;
}

fn solve(b: &mut Board) -> i32 {
    for i in 0..81 {
        if b.cells[i] == 0 {
            for n in 1..10 {
                if is_valid(b, (i / 9) as i32, (i % 9) as i32, n as u8) {
                    b.cells[i] = n as u8;
                    let result = solve(b);
                    if result == STATUS_FOUND { return STATUS_FOUND; }
                    b.cells[i] = 0;
                }
            }
            return STATUS_UNSOLVABLE; // Explicit Failure
        }
    }
    return STATUS_FOUND; // Explicit Success
}

fn main() -> i32 {
    let mut board = Board([0; 81]);
    for idx in 0..81 {
        let (r, c) = ((idx / 9) as i32, (idx % 9) as i32);
        board.cells[idx] = ((((r % 3) * 3 + (r / 3) + c) % 9) + 1) as u8;
    }
    board.cells[72] = 0; board.cells[73] = 0; board.cells[74] = 0;

    let start = Instant::now();
    if solve(&mut board) == STATUS_FOUND {
        let elapsed = start.elapsed();
        println(f"Solved! Time: {elapsed.as_nanos()} ns");
    } else {
        println("No solution.");
    }
    return 0;
}
