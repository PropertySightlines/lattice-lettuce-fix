// Matrix Multiplication Benchmark
//
// This benchmark demonstrates Salt's automatic polyhedral optimization via MLIR.
// The simple triple-nested loop below is automatically transformed by the compiler
// into cache-optimized, tiled code using the Affine Dialect.
//
// MLIR Optimization Pipeline:
//   1. Salt emits `affine.for` loops with `affine.load/store` operations
//   2. `affine-loop-tile="tile-size=32"` applies 32x32 cache blocking
//   3. The resulting code has much better cache locality
//
// Salt users write simple loops and get these optimizations automatically.

package main

fn main() -> i32 {
    let a = Tensor::<f64>(1.0, [1024, 1024]);
    let b = Tensor::<f64>(2.0, [1024, 1024]);
    let mut res = Tensor::<f64>(0.0, [1024, 1024]);
    
    // Simple nested loops - MLIR automatically applies:
    // - Loop tiling (32x32 blocks)
    // - Cache blocking
    // - Dependence-driven loop interchange
    for i in 0..1024 {
        for j in 0..1024 {
            for k in 0..1024 {
                res[(i, j)] += a[(i, k)] * b[(k, j)];
            }
        }
    }
    
    // Check first element: 1024 * 1.0 * 2.0 = 2048.0
    if res[(0, 0)] > 2047.0 && res[(0, 0)] < 2049.0 {
        return 0;
    }
    return 1;
}
