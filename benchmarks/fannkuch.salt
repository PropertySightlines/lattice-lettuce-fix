package main

// Fannkuch-Redux Benchmark — Ptr<i32> with [] indexing

use std.core.ptr.Ptr
use std.core.arena

fn fannkuch(n: i32) -> i32 {
    let size = (n * 4) as i64;
    let perm: Ptr<i32> = arena::alloc(size) as Ptr<i32>;
    let perm1: Ptr<i32> = arena::alloc(size) as Ptr<i32>;
    let count: Ptr<i32> = arena::alloc(size) as Ptr<i32>;
    
    let mut max_flips = 0;
    let mut checksum = 0;
    let mut perm_count = 0;
    
    for i in 0..n { perm1[i as i64] = i; }
    let mut r = n;
    
    while true {
        while r != 1 {
            count[(r - 1) as i64] = r;
            r -= 1;
        }
        
        for i in 0..n { perm[i as i64] = perm1[i as i64]; }
        
        let mut flips = 0;
        let mut k = perm[0 as i64];
        while k != 0 {
            let k2 = (k + 1) / 2;
            for i in 0..k2 {
                let temp = perm[i as i64];
                perm[i as i64] = perm[(k - i) as i64];
                perm[(k - i) as i64] = temp;
            }
            flips += 1;
            k = perm[0 as i64];
        }
        
        if flips > max_flips { max_flips = flips; }
        if perm_count % 2 == 0 { checksum += flips; } else { checksum -= flips; }
        perm_count += 1;
        
        // Generate next permutation
        while true {
            if r == n {
                return checksum * 1000 + max_flips;
            }
            let perm0 = perm1[0 as i64];
            for i in 0..r { perm1[i as i64] = perm1[(i + 1) as i64]; }
            perm1[r as i64] = perm0;
            let cnt = count[r as i64] - 1;
            count[r as i64] = cnt;
            if cnt > 0 { break; }
            r += 1;
        }
    }
    return 0;
}

fn main(argc: i32) -> i32 {
    let n = 10 + (argc - 1);
    let result = fannkuch(n);
    let checksum = result / 1000;
    let max_flips = result % 1000;
    if argc == 1 {
        if checksum == 73196 {
            if max_flips == 38 { return 0; }
        }
    }
    if max_flips > 0 { return 0; }
    return 1;
}
