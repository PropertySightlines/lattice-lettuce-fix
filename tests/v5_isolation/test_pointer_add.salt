
package main

extern fn alloc(bytes: u64) -> u64;

@no_mangle
fn main_salt() -> i32 {
    println("Testing V5.2 Sovereign Pointer (with Phantom Pointer Fix)...");
    
    // Allocate a buffer of 10 floats
    let base: &f32 = reinterpret_cast::<&f32>(alloc(40));
    
    // Initialize using pointer arithmetic - NOW with local Reference!
    for i in 0..10 {
        let idx = i as i32;
        let ptr = base + idx;  // V5.2 Sovereign Pointer: GEP!
        *ptr = (idx as f32) * 10.0;
    }
    
    // Verify using pointer arithmetic
    print("Values: ");
    for i in 0..10 {
        let ptr = base + (i as i32);
        let val = *ptr;
        print(f"{val} ");
    }
    println("");
    
    // Test commutative form: idx + ptr
    let middle = 5 + base;  // Should give same as base + 5
    println(f"Value at (5 + base): {*middle}");
    
    println("V5.2 Sovereign Pointer Test PASSED!");
    return 0;
}
