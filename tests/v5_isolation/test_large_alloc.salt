
package main

extern fn alloc(bytes: u64) -> u64;
extern fn salt_zeros_f32(ptr: &f32, count: u64);
extern fn salt_randn_f32(ptr: &f32, count: u64, scale: f32, seed: u32);

fn zeros(count: u64) -> Tensor<f32, {[1]}> {
    let ptr = alloc(count * 4); 
    salt_zeros_f32(reinterpret_cast::<&f32>(ptr), count);
    return reinterpret_cast::<Tensor<f32, {[1]}>>(ptr);
}

fn randn(count: u64, scale: f32) -> Tensor<f32, {[1]}> {
    let ptr = alloc(count * 4);
    salt_randn_f32(reinterpret_cast::<&f32>(ptr), count, scale, 42);
    return reinterpret_cast::<Tensor<f32, {[1]}>>(ptr);
}

@no_mangle
fn main_salt() -> i32 {
    println("Starting V5 Large Alloc Test...");
    
    // 128x784 * 784x1 -> 128x1
    // This matches the size of the failing operation in sovereign_train_v4
    // 128 * 784 * 4 bytes = ~400KB
    // If we have 3 of these on stack (LHS, RHS, Res) -> > 1MB. 
    // Default stack is often 8MB, but deep recursion or inlining can blow it up.
    // If the compiler emits `alloca` for these, it's risky.
    
    let w: Tensor<f32, {[128, 784]}> = reinterpret_cast(randn(128*784, 0.01));
    let x: Tensor<f32, {[784]}> = reinterpret_cast(randn(784, 0.01));
    let b: Tensor<f32, {[128]}> = reinterpret_cast(zeros(128));

    println("Allocated tensors. Performing MatVec...");
    
    // This triggers the V5 Linalg Lowering (BinOp::Mul)
    // Should allocate temp memrefs internally.
    let z = (w * x) + b;
    
    println("MatVec Done.");
    
    let ptr_addr = reinterpret_cast::<u64>(reinterpret_cast::<&f32>(z)) as i64;
    println(f"Result Address: {ptr_addr}");
    
    return 0;
}
