
package main

extern fn alloc(bytes: u64) -> u64;

fn zeros(count: u64) -> Tensor<f32, {[1]}> {
    let ptr = alloc(count * 4); 
    // Manual zeroing
    let t = reinterpret_cast::<Tensor<f32, {[1]}>>(ptr);
    for i in 0..count {
        t[(i,)] = 0.0;
    }
    return t;
}

fn eye_4() -> Tensor<f32, {[4, 4]}> {
    let t: Tensor<f32, {[4, 4]}> = reinterpret_cast(zeros(16));
    for i in 0..4 {
        t[(i as u64, i as u64)] = 1.0;
    }
    return t;
}

fn fill_4(val: f32) -> Tensor<f32, {[4, 4]}> {
    let t: Tensor<f32, {[4, 4]}> = reinterpret_cast(zeros(16));
    for i in 0..4 {
        for j in 0..4 {
            t[(i as u64, j as u64)] = val;
        }
    }
    return t;
}

@no_mangle
fn main_salt() -> i32 {
    println("Starting V5 Small MatMul Test...");
    
    // I = Identity 4x4
    let I = eye_4();
    // A = Fill(2.0) 4x4
    let A = fill_4(2.0);
    
    // B = I * A -> Should remain A
    let B = I * A;
    
    // Verify B is all 2.0
    println("Verifying I * A ...");
    let mut err = 0;
    for i in 0..4 {
        for j in 0..4 {
            let val = B[(i as u64, j as u64)];
            if val != 2.0 {
                print(f"Error at [{i as i64}, {i as i64}]: ");
                println(f"Expected 2.0, got {val}");
                err = 1;
            }
        }
    }
    
    if err == 0 {
        println("I * A Passed.");
    } else {
        println("I * A Failed.");
    }
    
    return 0;
}
