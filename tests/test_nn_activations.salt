// =============================================================================
// Test: std.nn.activations — relu, relu_grad, sigmoid, tanh_activation
// =============================================================================

package main

extern fn malloc(size: i64) -> Ptr<u8>;
extern fn expf(x: f32) -> f32;

// Functions under test: relu, relu_grad, sigmoid, tanh_activation
// These are compiler intrinsics (std.nn)

fn alloc_f32(count: i64) -> Ptr<f32> {
    let ptr: Ptr<u8> = malloc(count * 4);
    return ptr as Ptr<f32>;
}

fn approx_eq(a: f32, b: f32, tol: f32) -> bool {
    let diff = a - b;
    let abs_diff = if diff > 0.0f32 { diff } else { 0.0f32 - diff };
    return abs_diff < tol;
}

fn main() -> i32 {
    // ---- relu ----
    let buf = alloc_f32(4);
    buf[0] = 1.0f32;
    buf[1] = -2.0f32;
    buf[2] = 3.0f32;
    buf[3] = -0.5f32;

    relu(buf, 4);

    if !approx_eq(buf[0], 1.0f32, 0.001f32) { return 1; }
    if !approx_eq(buf[1], 0.0f32, 0.001f32) { return 2; }
    if !approx_eq(buf[2], 3.0f32, 0.001f32) { return 3; }
    if !approx_eq(buf[3], 0.0f32, 0.001f32) { return 4; }

    // ---- relu_grad ----
    if !approx_eq(relu_grad(5.0f32), 1.0f32, 0.001f32) { return 10; }
    if !approx_eq(relu_grad(-1.0f32), 0.0f32, 0.001f32) { return 11; }
    if !approx_eq(relu_grad(0.0f32), 0.0f32, 0.001f32) { return 12; }

    // ---- sigmoid ----
    let sig = alloc_f32(3);
    sig[0] = 0.0f32;
    sig[1] = 10.0f32;
    sig[2] = -10.0f32;

    sigmoid(sig, 3);

    // sigmoid(0) = 0.5
    if !approx_eq(sig[0], 0.5f32, 0.01f32) { return 20; }
    // sigmoid(10) ≈ 1.0
    if !approx_eq(sig[1], 1.0f32, 0.01f32) { return 21; }
    // sigmoid(-10) ≈ 0.0
    if !approx_eq(sig[2], 0.0f32, 0.01f32) { return 22; }

    // ---- tanh_activation ----
    let th = alloc_f32(3);
    th[0] = 0.0f32;
    th[1] = 2.0f32;
    th[2] = -2.0f32;

    tanh_activation(th, 3);

    // tanh(0) = 0.0
    if !approx_eq(th[0], 0.0f32, 0.01f32) { return 30; }
    // tanh(2) ≈ 0.9640
    if !approx_eq(th[1], 0.964f32, 0.01f32) { return 31; }
    // tanh(-2) ≈ -0.9640
    if !approx_eq(th[2], -0.964f32, 0.01f32) { return 32; }

    println("nn activations: PASS");
    return 0;
}
