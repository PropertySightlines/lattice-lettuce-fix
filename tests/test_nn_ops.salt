// =============================================================================
// Test: std.nn.ops — add_bias, zeros, scale, argmax
// =============================================================================

package main

extern fn malloc(size: i64) -> Ptr<u8>;

// Functions under test: add_bias, zeros, scale, argmax
// These are compiler intrinsics (std.nn)

fn alloc_f32(count: i64) -> Ptr<f32> {
    let ptr: Ptr<u8> = malloc(count * 4);
    return ptr as Ptr<f32>;
}

fn approx_eq(a: f32, b: f32, tol: f32) -> bool {
    let diff = a - b;
    let abs_diff = if diff > 0.0f32 { diff } else { 0.0f32 - diff };
    return abs_diff < tol;
}

fn main() -> i32 {
    // ---- add_bias ----
    let dst = alloc_f32(4);
    dst[0] = 1.0f32;
    dst[1] = 2.0f32;
    dst[2] = 3.0f32;
    dst[3] = 4.0f32;

    let bias = alloc_f32(4);
    bias[0] = 0.1f32;
    bias[1] = 0.2f32;
    bias[2] = 0.3f32;
    bias[3] = 0.4f32;

    add_bias(dst, 4, bias);

    if !approx_eq(dst[0], 1.1f32, 0.001f32) { return 1; }
    if !approx_eq(dst[1], 2.2f32, 0.001f32) { return 2; }
    if !approx_eq(dst[2], 3.3f32, 0.001f32) { return 3; }
    if !approx_eq(dst[3], 4.4f32, 0.001f32) { return 4; }

    // ---- zeros ----
    let z = alloc_f32(4);
    z[0] = 99.0f32;
    z[1] = 88.0f32;
    z[2] = 77.0f32;
    z[3] = 66.0f32;

    zeros(z, 4);

    if !approx_eq(z[0], 0.0f32, 0.001f32) { return 10; }
    if !approx_eq(z[1], 0.0f32, 0.001f32) { return 11; }
    if !approx_eq(z[2], 0.0f32, 0.001f32) { return 12; }
    if !approx_eq(z[3], 0.0f32, 0.001f32) { return 13; }

    // ---- scale ----
    let s = alloc_f32(3);
    s[0] = 1.0f32;
    s[1] = 2.0f32;
    s[2] = 3.0f32;

    scale(s, 3, 2.0f32);

    if !approx_eq(s[0], 2.0f32, 0.001f32) { return 20; }
    if !approx_eq(s[1], 4.0f32, 0.001f32) { return 21; }
    if !approx_eq(s[2], 6.0f32, 0.001f32) { return 22; }

    // ---- argmax ----
    let a = alloc_f32(5);
    a[0] = 1.0f32;
    a[1] = 5.0f32;
    a[2] = 3.0f32;
    a[3] = 9.0f32;
    a[4] = 2.0f32;

    let idx = argmax(a, 5);
    if idx != 3 { return 30; }

    // Edge case: first element is max
    a[0] = 100.0f32;
    let idx2 = argmax(a, 5);
    if idx2 != 0 { return 31; }

    println("nn ops: PASS");
    return 0;
}
