// =============================================================================
// tests/test_udp_parse_build.salt
// UDP Header Parse/Build Round-Trip — Unit Test
// =============================================================================
//
// Verifies the byte-level UDP header contract (8 bytes):
//   [Src Port (BE)][Dst Port (BE)][Length (BE)][Checksum (BE)]
//
// UDP checksum is set to 0x0000 (valid for IPv4 per RFC 768).
// =============================================================================

package main

use std.core.ptr.Ptr

extern fn puts(s: Ptr<u8>) -> i32;
extern fn malloc(size: i64) -> u64;
extern fn free(ptr: u64);
extern fn exit(code: i32);

// --- Pure functions under test (mirror of kernel/net/udp.salt) ---------------

struct UDPHeader {
    src_port: u16,
    dst_port: u16,
    length: u16,
}

fn udp_parse(buf: u64, len: u32) -> UDPHeader {
    let mut hdr = UDPHeader {
        src_port: 0,
        dst_port: 0,
        length: 0,
    };

    if len < 8 {
        return hdr;
    }

    let sp_hi = *(buf as &u8) as u16;
    let sp_lo = *((buf + 1) as &u8) as u16;
    hdr.src_port = (sp_hi << 8) | sp_lo;

    let dp_hi = *((buf + 2) as &u8) as u16;
    let dp_lo = *((buf + 3) as &u8) as u16;
    hdr.dst_port = (dp_hi << 8) | dp_lo;

    let l_hi = *((buf + 4) as &u8) as u16;
    let l_lo = *((buf + 5) as &u8) as u16;
    hdr.length = (l_hi << 8) | l_lo;

    return hdr;
}

fn udp_build(buf: u64, src_port: u16, dst_port: u16, payload_len: u16) -> u32 {
    let udp_len: u16 = 8 + payload_len;

    *(buf as &mut u8) = (src_port >> 8) as u8;
    *((buf + 1) as &mut u8) = (src_port & 0xFF) as u8;

    *((buf + 2) as &mut u8) = (dst_port >> 8) as u8;
    *((buf + 3) as &mut u8) = (dst_port & 0xFF) as u8;

    *((buf + 4) as &mut u8) = (udp_len >> 8) as u8;
    *((buf + 5) as &mut u8) = (udp_len & 0xFF) as u8;

    *((buf + 6) as &mut u8) = 0;
    *((buf + 7) as &mut u8) = 0;

    return 8;
}

// --- Test helpers -----------------------------------------------------------

fn fail(msg: Ptr<u8>) {
    puts(msg);
    exit(1);
}

// --- Tests ------------------------------------------------------------------

fn main() -> i32 {
    let buf = malloc(32);
    if buf == 0 {
        fail("FAIL: malloc returned null" as Ptr<u8>);
        return 1;
    }

    let mut z: i32 = 0;
    while z < 32 {
        *((buf + z as u64) as &mut u8) = 0;
        z = z + 1;
    }

    // ---- Test 1: Build→Parse round-trip ------------------------------------
    let sz = udp_build(buf, 5555, 7, 10);
    if sz != 8 {
        fail("FAIL: udp_build did not return 8" as Ptr<u8>);
    }

    let hdr = udp_parse(buf, 8);
    if hdr.src_port != 5555 {
        fail("FAIL: parsed src_port != 5555" as Ptr<u8>);
    }
    if hdr.dst_port != 7 {
        fail("FAIL: parsed dst_port != 7" as Ptr<u8>);
    }

    // ---- Test 2: Length field -----------------------------------------------
    // length = 8 (header) + 10 (payload) = 18
    if hdr.length != 18 {
        fail("FAIL: parsed length != 18" as Ptr<u8>);
    }

    // ---- Test 3: Checksum zero ---------------------------------------------
    let csum_hi = *((buf + 6) as &u8);
    let csum_lo = *((buf + 7) as &u8);
    if csum_hi != 0 {
        fail("FAIL: checksum byte 6 != 0x00" as Ptr<u8>);
    }
    if csum_lo != 0 {
        fail("FAIL: checksum byte 7 != 0x00" as Ptr<u8>);
    }

    // ---- Test 4: Big-endian port encoding ----------------------------------
    // dst_port=7 → byte[2]=0x00, byte[3]=0x07
    let byte2 = *((buf + 2) as &u8);
    let byte3 = *((buf + 3) as &u8);
    if byte2 != 0x00 {
        fail("FAIL: dst_port byte[2] != 0x00" as Ptr<u8>);
    }
    if byte3 != 0x07 {
        fail("FAIL: dst_port byte[3] != 0x07" as Ptr<u8>);
    }

    // Also check src_port=5555 (0x15B3) → byte[0]=0x15, byte[1]=0xB3
    let byte0 = *(buf as &u8);
    let byte1 = *((buf + 1) as &u8);
    if byte0 != 0x15 {
        fail("FAIL: src_port byte[0] != 0x15" as Ptr<u8>);
    }
    if byte1 != 0xB3 {
        fail("FAIL: src_port byte[1] != 0xB3" as Ptr<u8>);
    }

    // ---- Test 5: Short buffer rejection ------------------------------------
    let hdr2 = udp_parse(buf, 7);
    if hdr2.src_port != 0 {
        fail("FAIL: short buffer should return zeroed header" as Ptr<u8>);
    }
    if hdr2.dst_port != 0 {
        fail("FAIL: short buffer should return zeroed dst_port" as Ptr<u8>);
    }

    // ---- Test 6: Large port numbers ----------------------------------------
    // Verify max port (65535 = 0xFFFF)
    udp_build(buf, 65535, 65535, 0);
    let hdr3 = udp_parse(buf, 8);
    if hdr3.src_port != 65535 {
        fail("FAIL: max src_port round-trip failed" as Ptr<u8>);
    }
    if hdr3.dst_port != 65535 {
        fail("FAIL: max dst_port round-trip failed" as Ptr<u8>);
    }

    free(buf);
    puts("PASS: all udp tests" as Ptr<u8>);
    return 0;
}
