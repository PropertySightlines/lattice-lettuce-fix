// tests/test_drop.salt — TDD test for Drop trait (RAII)
// Verifies that drop() is called automatically at scope exit.
package main

extern fn exit(code: i32);

struct Resource {
    id: i64
}

impl Resource {
    pub fn drop(&mut self) {
        println("  Resource {} dropped", self.id);
    }
}

fn main() -> i32 {
    println("=== Drop Trait Tests ===");

    // Test 1: Drop should be called before main returns
    println("Test 1: Basic drop");
    let mut r1 = Resource { id: 1 };
    println("  Resource 1 created");
    let mut r2 = Resource { id: 2 };
    println("  Resource 2 created");

    // Test 2: Function with return — drop called before return
    println("Test 2: Function scope drop");
    do_work();

    println("=== End of main (r1, r2 should be dropped) ===");
    // r1 and r2 should be dropped here automatically
    return 0;
}

fn do_work() {
    let mut r = Resource { id: 3 };
    println("  Resource 3 created (in do_work)");
    println("  Returning from do_work...");
    return;
    // r.drop() should be called before this return
}
