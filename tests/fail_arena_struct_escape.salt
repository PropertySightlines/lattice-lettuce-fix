// ============================================================================
// XFAIL: Arena Scope Infection — pointer smuggled via struct field
// ============================================================================
// STATUS: Currently compiles. MUST fail compilation once escape analysis
//         detects cross-lifetime pointer stores.
//
// Expected future error:
//   "Error: Pointer 'data' (arena lifetime: local_arena) stored into
//    'ctx.saved_ptr' (arena lifetime: main_arena). Lifetime mismatch."
//
// Until then, this file documents the safety gap.
// ============================================================================

package main

import std.core.arena.Arena
import std.core.ptr.Ptr

struct Context {
    saved_ptr: Ptr<i64>
}

// ❌ DANGER: Stores short-lived arena pointer into long-lived struct
fn leak_via_struct(ctx: Ptr<Context>) {
    let local_arena = Arena::new(4096);
    let data = local_arena.alloc::<i64>(99);

    // Storing a pointer from local_arena into ctx (which lives in main_arena).
    // When local_arena dies at end of this function, ctx.saved_ptr dangles.
    ctx.saved_ptr = data;
} // local_arena dies. ctx.saved_ptr is now dangling.

fn main() -> i32 {
    let main_arena = Arena::new(4096);
    let null_ptr = Ptr<i64>::from_addr(0u64);
    let ctx = main_arena.alloc::<Context>(Context { saved_ptr: null_ptr });

    leak_via_struct(ctx);

    // ctx.saved_ptr is dangling — reads garbage or crashes.
    // This SHOULD be a compile-time error.
    return 0;
}
