// ============================================================================
// XFAIL: Arena Escape — pointer outlives its arena
// ============================================================================
// STATUS: Currently compiles. MUST fail compilation once escape analysis
//         is implemented (Phase 4.3).
//
// Expected future error:
//   "Error: Pointer 'n' escapes the lifetime of its arena."
//
// Until then, this file documents the safety gap.
// ============================================================================

package main

import std.core.arena.Arena

struct Node { val: i64 }

// ❌ DANGER: Returns a pointer to memory owned by a local arena
fn create_dangling() -> Ptr<Node> {
    let arena = Arena::new(4096);
    let n = arena.alloc::<Node>(Node { val: 100 });
    // n points to memory owned by 'arena'
    return n;
} // 'arena' dies here. 'n' is now a dangling pointer.

fn main() -> i32 {
    let bad_ptr = create_dangling();

    // This SHOULD be a compile-time error:
    //   "Pointer 'n' escapes the lifetime of its arena."
    // Currently: compiles, runs, reads stale/poisoned data.
    return bad_ptr.val as i32;
}
