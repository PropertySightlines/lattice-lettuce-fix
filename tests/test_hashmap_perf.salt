// test_hashmap_perf.salt - TDD test to isolate HashMap performance issue
// Minimal benchmark of just insert + get operations

use std.collections.hash_map.HashMap

fn main() -> i32 {
    // Simple benchmark: 1000 iterations of insert/get on small map
    let mut total: i64 = 0;
    
    let mut round: i64 = 0;
    while round < 1000 {
        let mut map = HashMap<i64, i64>::with_capacity(100);
        
        // Insert 100 items
        let mut i: i64 = 0;
        while i < 100 {
            map.insert(i, i * 10);
            i = i + 1;
        }
        
        // Get 100 items
        i = 0;
        while i < 100 {
            total = total + map.get(i);
            i = i + 1;
        }
        
        map.drop();
        round = round + 1;
    }
    
    println(f"Total: {total}");
    return 0;
}
