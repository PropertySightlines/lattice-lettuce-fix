fn nested_verification(n: i32) -> i32 {
    let a = Tensor<i32, 1024>::zeros();
    let mut sum = 0;
    
    // Proving safety for simple loop
    for i in 0..1024 {
        sum += a[(i)]; // Should be elided
    }
    
    // Proving safety for nested loop
    let b = Tensor<i32, 32, 32>::zeros();
    for i in 0..32 {
        for j in 0..32 {
            sum += b[(i, j)]; // Should be elided
        }
    }
    
    // Proving safety with function contract
    sum += checked_access(a, 512); // Should be safe because 512 < 1024
    
    return sum;
}

fn checked_access(t: Tensor<i32, 1024>, idx: i32) -> i32 
requires { idx >= 0 && idx < 1024 }
{
    return t[(idx)]; // Should be elided due to 'requires'
}

fn main() -> i32 {
    let res = nested_verification(1024);
    if res == 0 { return 0; }
    return 1;
}
