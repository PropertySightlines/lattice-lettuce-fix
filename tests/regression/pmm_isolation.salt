// tests/regression/pmm_isolation.salt
// Regression Test: PMM Stack Isolation
// Ensures that 'requires' contracts emit salt.verify ops.

struct PmmState { top: u64 }
global PMM: PmmState;

fn alloc() -> u64 
    requires { PMM.top != 0 } 
{
    PMM.top = PMM.top - 1;
    return 0;
}

// CHECK: arith\.cmpi "ne"
// CHECK: "salt\.verify"\(%cond\) \{kind = "requires"\} : \(i1\) -> \(\)
