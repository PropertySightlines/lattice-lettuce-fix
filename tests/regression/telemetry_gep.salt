// tests/regression/telemetry_gep.salt
// Verifies that large array access generates correct GEP without aggregate loads.
// 
// CHECK: llvm.mlir.global internal @benchmarks__ring_of_fire__TELEMETRY_SAMPLES
// CHECK: llvm.getelementptr
// CHECK-NOT: llvm.load{{.*}}!llvm.array<10000 x i64>
// CHECK: llvm.readcyclecounter

package benchmarks.ring_of_fire

import kernel.core.timing;

const MAX_SAMPLES: u64 = 10000;

global TELEMETRY_SAMPLES: [u64; 10000] = [0; 10000];
global SAMPLE_COUNT: u64 = 0;

fn record_sample(gap: u64) {
    let idx = SAMPLE_COUNT;
    if idx < MAX_SAMPLES {
        // This must generate GEP [0, idx], not load the array
        TELEMETRY_SAMPLES[idx] = gap;
        SAMPLE_COUNT = idx + 1;
    }
}

fn read_sample(idx: u64) -> u64 {
    // This must generate GEP [0, idx], then load i64
    return TELEMETRY_SAMPLES[idx];
}

fn get_cycles() -> u64 {
    // This must lower to llvm.readcyclecounter
    return intrinsic.rdtsc() as u64;
}

pub fn main() {
    let cycles = get_cycles();
    record_sample(cycles);
    let val = read_sample(0);
}
