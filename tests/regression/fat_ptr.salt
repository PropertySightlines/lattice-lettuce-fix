// tests/regression/fat_ptr.salt
// Regression Test: Fat Pointer Packaging
// Ensures that Windows are passed as {ptr, len} structs in MLIR.

fn test_fat_ptr(s: Window<u8>) -> u64 {
    // Should extract length from the second element of the struct
    return s.len;
}

// CHECK: !llvm\.struct<\(!llvm\.ptr, i64\)>
// CHECK: llvm\.getelementptr .*\[0, 1\] : \(!llvm\.ptr\) -> !llvm\.ptr, !llvm\.struct<\(!llvm\.ptr, i64\)>
// CHECK: llvm\.load .* : !llvm\.ptr -> i64
