package tests.fail_oob

// This test attempts to write beyond the implicitly verified 4096-byte region.
// We use a scalar variable treated as the "base" allocation.

fn trigger_oob() {
    let mut val: i32 = 0;
    let ptr = &mut val;
    
    // Attempt to access at offset > 4096 bytes
    // sizeof(i32) = 4 bytes.
    // 1025 * 4 = 4100 bytes.
    
    unsafe {
       // Pointer arithmetic: ptr + n offsets by n * sizeof(T)
       let modified_ptr = ptr + 1025; 
       *modified_ptr = 0xDEADBEEF;
    }
}

pub fn main() {
    trigger_oob();
}
