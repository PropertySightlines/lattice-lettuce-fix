// test_ptr_bounds.salt — End-to-end test for pointer bounds patterns
// Tests Ptr<T> operations in bounded contexts (loops, requires contracts).
// Uses Arena for allocation — no raw malloc needed.

package test.ptr_bounds

use std.io.println
use std.core.ptr.Ptr
use std.core.arena.Arena

fn sum_via_ptr(ptr: Ptr<i64>, len: i64) -> i64
    requires len >= 0
{
    let mut total: i64 = 0;
    for i in 0..len {
        let val: i64 = ptr.index(i);
        total = total + val;
    }
    return total;
}

fn fill_ptr(ptr: Ptr<i64>, len: i64, value: i64)
    requires len >= 0
{
    for i in 0..len {
        ptr.offset(i).write(value);
    }
}

fn main() {
    let arena = Arena::new(4096);
    let size: i64 = 8;

    // Allocate via Arena — returns Ptr<i64>
    let ptr: Ptr<i64> = arena.alloc_array::<i64>(size);

    // Fill with values 0..7
    for i in 0..size {
        ptr.offset(i).write(i);
    }

    // Test 1: Sum via pointer with requires contract
    let total: i64 = sum_via_ptr(ptr, size);
    println(f"sum_via_ptr = {total}");  // 28

    // Test 2: Fill with constant and verify
    fill_ptr(ptr, size, 42);
    let check: i64 = ptr.index(0);
    println(f"fill check = {check}");  // 42
}
