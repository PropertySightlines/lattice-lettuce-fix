// =============================================================================
// test_reactor.salt — TDD Tests for the I/O Reactor Abstraction
// =============================================================================
// Validates the Reactor trait contract and both backends:
//   - KqueueReactor: creation, register, wait, deregister (live kqueue)
//   - LatticeReactor: graceful failure (stub returns proper Status)
//
// Run: ./scripts/run_test.sh tests/test_reactor.salt --bridge std/net/http_bridge.c
// =============================================================================

package main

use std.core.ptr.Ptr
use std.core.result.Result
use std.io.reactor.{Reactor, Filter}
use std.io.reactor_kqueue.KqueueReactor
use std.io.reactor_lattice.LatticeReactor

extern fn exit(code: i32);
extern fn pipe(fds: Ptr<i32>) -> i32;
extern fn write(fd: i32, buf: Ptr<u8>, count: i64) -> i64;
extern fn close(fd: i32) -> i32;

// ============================================================================
// Test Helpers
// ============================================================================

fn assert_true(cond: bool, test_id: i32) {
    if !cond {
        println(f"FAIL test {test_id}");
        exit(test_id);
    }
}

fn assert_eq(got: i64, expected: i64, test_id: i32) {
    if got != expected {
        println(f"FAIL test {test_id}: got {got}, expected {expected}");
        exit(test_id);
    }
}

// ============================================================================
// Test 1: KqueueReactor creation succeeds
// ============================================================================

fn test_kqueue_reactor_new() {
    let result = KqueueReactor::new();
    assert_true(result.is_ok(), 1);

    let reactor = result.unwrap();
    let fd = reactor.fd();
    assert_true(fd >= 0, 1);

    println("PASS test_kqueue_reactor_new");
}

// ============================================================================
// Test 2: KqueueReactor register/wait round-trip with pipe
// Verifies the full event loop contract: register a readable fd,
// write to it, wait for the event, confirm the fd is returned.
// ============================================================================

fn test_kqueue_reactor_register_wait() {
    let result = KqueueReactor::new();
    assert_true(result.is_ok(), 2);
    let reactor = result.unwrap();

    // Create a pipe: fds[0] = read end, fds[1] = write end
    let mut fds: [i32; 2] = [0; 2];
    let pipe_ret = pipe(&fds[0] as Ptr<i32>);
    assert_eq(pipe_ret as i64, 0, 2);

    let read_fd = fds[0];
    let write_fd = fds[1];

    // Register the read end for Read events
    let reg_ret = reactor.register(read_fd, Filter::Read);
    assert_eq(reg_ret as i64, 0, 2);

    // Write a byte to make the read end readable
    let mut data: [u8; 1] = [42; 1];
    let written = write(write_fd, &data[0] as Ptr<u8>, 1);
    assert_eq(written, 1, 2);

    // Wait for events (timeout 100ms)
    let mut events: [i64; 4] = [0; 4];
    let nev = reactor.wait(&events[0] as Ptr<i64>, 2, 100);
    assert_true(nev > 0, 2);

    // The first event should be our read fd
    assert_eq(events[0], read_fd as i64, 2);
    assert_eq(events[1], 0, 2);  // 0 = Filter::Read

    // Cleanup
    reactor.deregister(read_fd);
    close(read_fd);
    close(write_fd);

    println("PASS test_kqueue_reactor_register_wait");
}

// ============================================================================
// Test 3: KqueueReactor deregister removes fd from event set
// After deregistering, wait() should not report events for that fd.
// ============================================================================

fn test_kqueue_reactor_deregister() {
    let result = KqueueReactor::new();
    assert_true(result.is_ok(), 3);
    let reactor = result.unwrap();

    let mut fds: [i32; 2] = [0; 2];
    let pipe_ret = pipe(&fds[0] as Ptr<i32>);
    assert_eq(pipe_ret as i64, 0, 3);

    let read_fd = fds[0];
    let write_fd = fds[1];

    // Register, then deregister
    reactor.register(read_fd, Filter::Read);
    // Note: deregister return code may be non-zero if the underlying kqueue
    // EV_DELETE fails for a filter that wasn't registered (e.g., EVFILT_WRITE).
    // The behavioral contract is what matters: the fd must no longer be polled.
    reactor.deregister(read_fd);

    // Write to make readable
    let mut data: [u8; 1] = [42; 1];
    write(write_fd, &data[0] as Ptr<u8>, 1);

    // Wait with 0ms timeout (poll). Should return 0 events since fd is deregistered.
    let mut events: [i64; 4] = [0; 4];
    let nev = reactor.wait(&events[0] as Ptr<i64>, 2, 0);
    assert_eq(nev as i64, 0, 3);

    close(read_fd);
    close(write_fd);

    println("PASS test_kqueue_reactor_deregister");
}

// ============================================================================
// Test 4: KqueueReactor wait timeout with no events
// Poll with 0ms timeout when nothing is ready. Should return 0.
// ============================================================================

fn test_kqueue_reactor_wait_timeout() {
    let result = KqueueReactor::new();
    assert_true(result.is_ok(), 4);
    let reactor = result.unwrap();

    let mut fds: [i32; 2] = [0; 2];
    let pipe_ret = pipe(&fds[0] as Ptr<i32>);
    assert_eq(pipe_ret as i64, 0, 4);

    // Register read end but don't write anything
    reactor.register(fds[0], Filter::Read);

    let mut events: [i64; 4] = [0; 4];
    let nev = reactor.wait(&events[0] as Ptr<i64>, 2, 0);
    assert_eq(nev as i64, 0, 4);

    reactor.deregister(fds[0]);
    close(fds[0]);
    close(fds[1]);

    println("PASS test_kqueue_reactor_wait_timeout");
}

// ============================================================================
// Test 5: KqueueReactor Write filter
// Register for Write events on the write end of a pipe,
// which should be immediately writable.
// ============================================================================

fn test_kqueue_reactor_write_filter() {
    let result = KqueueReactor::new();
    assert_true(result.is_ok(), 5);
    let reactor = result.unwrap();

    let mut fds: [i32; 2] = [0; 2];
    let pipe_ret = pipe(&fds[0] as Ptr<i32>);
    assert_eq(pipe_ret as i64, 0, 5);

    let write_fd = fds[1];

    // Register write end for Write events — should be immediately writable
    let reg_ret = reactor.register(write_fd, Filter::Write);
    assert_eq(reg_ret as i64, 0, 5);

    let mut events: [i64; 4] = [0; 4];
    let nev = reactor.wait(&events[0] as Ptr<i64>, 2, 100);
    assert_true(nev > 0, 5);
    assert_eq(events[0], write_fd as i64, 5);
    assert_eq(events[1], 1, 5);  // 1 = Filter::Write

    reactor.deregister(write_fd);
    close(fds[0]);
    close(fds[1]);

    println("PASS test_kqueue_reactor_write_filter");
}

// ============================================================================
// Test 6: LatticeReactor::new() fails gracefully
// The stub must return Err(Status), not panic or crash.
// This validates Salt's core pillar: Result<T> with Status.
// ============================================================================

fn test_lattice_reactor_fails_gracefully() {
    let result = LatticeReactor::new();
    assert_true(result.is_err(), 6);

    println("PASS test_lattice_reactor_fails_gracefully");
}

// ============================================================================
// Test 7: Multiple fds on one reactor
// Register two pipes, write to both, verify both events returned.
// ============================================================================

fn test_kqueue_reactor_multiple_fds() {
    let result = KqueueReactor::new();
    assert_true(result.is_ok(), 7);
    let reactor = result.unwrap();

    // Pipe 1
    let mut fds1: [i32; 2] = [0; 2];
    pipe(&fds1[0] as Ptr<i32>);
    // Pipe 2
    let mut fds2: [i32; 2] = [0; 2];
    pipe(&fds2[0] as Ptr<i32>);

    reactor.register(fds1[0], Filter::Read);
    reactor.register(fds2[0], Filter::Read);

    // Write to both pipes
    let mut data: [u8; 1] = [1; 1];
    write(fds1[1], &data[0] as Ptr<u8>, 1);
    write(fds2[1], &data[0] as Ptr<u8>, 1);

    // Wait — should get 2 events
    let mut events: [i64; 8] = [0; 8];
    let nev = reactor.wait(&events[0] as Ptr<i64>, 4, 100);
    assert_eq(nev as i64, 2, 7);

    // Both fds should appear (order may vary)
    let fd_a = events[0] as i32;
    let fd_b = events[2] as i32;
    let got_both = (fd_a == fds1[0] && fd_b == fds2[0]) ||
                   (fd_a == fds2[0] && fd_b == fds1[0]);
    assert_true(got_both, 7);

    reactor.deregister(fds1[0]);
    reactor.deregister(fds2[0]);
    close(fds1[0]);
    close(fds1[1]);
    close(fds2[0]);
    close(fds2[1]);

    println("PASS test_kqueue_reactor_multiple_fds");
}

// ============================================================================
// Main
// ============================================================================
fn main() -> i32 {
    println("=== Reactor Abstraction Tests ===");

    test_kqueue_reactor_new();
    test_kqueue_reactor_register_wait();
    test_kqueue_reactor_deregister();
    test_kqueue_reactor_wait_timeout();
    test_kqueue_reactor_write_filter();
    test_lattice_reactor_fails_gracefully();
    test_kqueue_reactor_multiple_fds();

    println("=== All 7 reactor tests passed ===");
    return 0;
}
