// =============================================================================
// tests/test_ip_checksum.salt
// RFC 1071 Internet Checksum — Unit Test
// =============================================================================
//
// Validates the one's complement checksum algorithm against known test vectors.
// This is the same checksum used by kernel/net/ip.salt for IPv4 headers.
//
// Key properties:
//   - checksum([all zeros]) == 0xFFFF
//   - checksum([all ones])  == 0x0000
//   - A valid IP header's checksum recomputes to 0x0000 (self-test)
//   - RFC 1071 Section 3 example produces correct result
// =============================================================================

package main

use std.core.ptr.Ptr

extern fn puts(s: Ptr<u8>) -> i32;
extern fn malloc(size: i64) -> u64;
extern fn free(ptr: u64);
extern fn exit(code: i32);

// --- Function under test (mirror of kernel/net/ip.salt) ----------------------

fn checksum(buf: u64, len: u32) -> u16 {
    let mut sum: u32 = 0;
    let mut i: u32 = 0;

    while i + 1 < len {
        let hi = *((buf + i as u64) as &u8) as u32;
        let lo = *((buf + i as u64 + 1) as &u8) as u32;
        sum = sum + ((hi << 8) | lo);
        i = i + 2;
    }

    if i < len {
        let hi = *((buf + i as u64) as &u8) as u32;
        sum = sum + (hi << 8);
    }

    while (sum >> 16) != 0 {
        sum = (sum & 0xFFFF) + (sum >> 16);
    }

    return (sum ^ 0xFFFF) as u16;
}

// --- Test helpers -----------------------------------------------------------

fn fail(msg: Ptr<u8>) {
    puts(msg);
    exit(1);
}

// --- Tests ------------------------------------------------------------------

fn main() -> i32 {
    let buf = malloc(64);
    if buf == 0 {
        fail("FAIL: malloc returned null" as Ptr<u8>);
        return 1;
    }

    // ---- Test 1: RFC 1071 example vector -----------------------------------
    // Input: 0x0001, 0xF203, 0xF4F5, 0xF6F7  (8 bytes)
    // Expected checksum: 0x220D
    *(buf as &mut u8) = 0x00;
    *((buf + 1) as &mut u8) = 0x01;
    *((buf + 2) as &mut u8) = 0xF2;
    *((buf + 3) as &mut u8) = 0x03;
    *((buf + 4) as &mut u8) = 0xF4;
    *((buf + 5) as &mut u8) = 0xF5;
    *((buf + 6) as &mut u8) = 0xF6;
    *((buf + 7) as &mut u8) = 0xF7;

    let cs1 = checksum(buf, 8);
    if cs1 != 0x220D {
        fail("FAIL: RFC 1071 vector checksum != 0x220D" as Ptr<u8>);
    }

    // ---- Test 2: All zeros → 0xFFFF ----------------------------------------
    let mut i: i32 = 0;
    while i < 4 {
        *((buf + i as u64) as &mut u8) = 0;
        i = i + 1;
    }
    let cs2 = checksum(buf, 4);
    if cs2 != 0xFFFF {
        fail("FAIL: all-zeros checksum != 0xFFFF" as Ptr<u8>);
    }

    // ---- Test 3: All ones → 0x0000 -----------------------------------------
    let mut j: i32 = 0;
    while j < 4 {
        *((buf + j as u64) as &mut u8) = 0xFF;
        j = j + 1;
    }
    let cs3 = checksum(buf, 4);
    if cs3 != 0x0000 {
        fail("FAIL: all-ones checksum != 0x0000" as Ptr<u8>);
    }

    // ---- Test 4: Odd-length buffer -----------------------------------------
    // 3 bytes: [0x01, 0x02, 0x03] — padded internally to [0x01, 0x02, 0x03, 0x00]
    // Manually: sum = 0x0102 + 0x0300 = 0x0402, ~0x0402 = 0xFBFD
    *(buf as &mut u8) = 0x01;
    *((buf + 1) as &mut u8) = 0x02;
    *((buf + 2) as &mut u8) = 0x03;
    let cs4 = checksum(buf, 3);
    if cs4 != 0xFBFD {
        fail("FAIL: odd-length checksum != 0xFBFD" as Ptr<u8>);
    }

    // ---- Test 5: IP header self-test (build then verify) --------------------
    // Build a minimal IP header and verify checksum self-validates to 0x0000
    // Version=4, IHL=5, TOS=0, Total=40, ID=0, Flags=DF, TTL=64, Proto=17
    // Src=10.0.2.15, Dst=10.0.2.2
    *(buf as &mut u8) = 0x45;
    *((buf + 1) as &mut u8) = 0x00;
    *((buf + 2) as &mut u8) = 0x00;   // total_len=40
    *((buf + 3) as &mut u8) = 0x28;
    *((buf + 4) as &mut u8) = 0x00;   // id=0
    *((buf + 5) as &mut u8) = 0x00;
    *((buf + 6) as &mut u8) = 0x40;   // DF flag
    *((buf + 7) as &mut u8) = 0x00;
    *((buf + 8) as &mut u8) = 0x40;   // TTL=64
    *((buf + 9) as &mut u8) = 0x11;   // UDP=17
    *((buf + 10) as &mut u8) = 0x00;  // checksum=0 (for computation)
    *((buf + 11) as &mut u8) = 0x00;
    *((buf + 12) as &mut u8) = 0x0A;  // src=10.0.2.15
    *((buf + 13) as &mut u8) = 0x00;
    *((buf + 14) as &mut u8) = 0x02;
    *((buf + 15) as &mut u8) = 0x0F;
    *((buf + 16) as &mut u8) = 0x0A;  // dst=10.0.2.2
    *((buf + 17) as &mut u8) = 0x00;
    *((buf + 18) as &mut u8) = 0x02;
    *((buf + 19) as &mut u8) = 0x02;

    // Compute checksum
    let cs_computed = checksum(buf, 20);
    // Write it back
    *((buf + 10) as &mut u8) = (cs_computed >> 8) as u8;
    *((buf + 11) as &mut u8) = (cs_computed & 0xFF) as u8;
    // Recompute — must be 0x0000
    let cs_verify = checksum(buf, 20);
    if cs_verify != 0x0000 {
        fail("FAIL: IP header self-test checksum != 0x0000" as Ptr<u8>);
    }

    // ---- Test 6: Single 16-bit word ----------------------------------------
    // Input: 0xABCD → ~0xABCD = 0x5432
    *(buf as &mut u8) = 0xAB;
    *((buf + 1) as &mut u8) = 0xCD;
    let cs6 = checksum(buf, 2);
    if cs6 != 0x5432 {
        fail("FAIL: single word checksum != 0x5432" as Ptr<u8>);
    }

    free(buf);
    puts("PASS: all checksum tests" as Ptr<u8>);
    return 0;
}
