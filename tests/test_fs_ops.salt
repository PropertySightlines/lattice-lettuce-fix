// =============================================================================
// std.fs — TDD Test Suite
// =============================================================================
// Tests filesystem operations: exists, create_dir, remove_dir, remove_file,
// read_dir with DirEntry iteration. All APIs return Result<T> with Status.
// Upholds Salt's three pillars: Result<T>, canonical Status codes, explicit return.

package main

use std.core.result.Result
use std.status.Status
use std.fs.fs
use std.core.ptr.Ptr

extern fn exit(code: i32);
extern fn malloc(size: i64) -> Ptr<u8>;
extern fn free(ptr: Ptr<u8>);

fn assert_true(cond: bool, test_id: i32) {
    if !cond {
        println(f"FAIL test {test_id}");
        exit(test_id);
    }
}

fn main() -> i32 {
    let mut passed: i64 = 0;
    let mut failed: i64 = 0;

    println("=== Filesystem Operations Tests ===");

    // =========================================================================
    // Test 1: exists() on a known path → true
    // =========================================================================
    let e1 = fs::exists("/tmp\0");
    assert_true(e1 == true, 1);
    println("  [PASS] exists(\"/tmp\") -> true");
    passed += 1;

    // =========================================================================
    // Test 2: exists() on a nonexistent path → false
    // =========================================================================
    let e2 = fs::exists("/tmp/salt_nonexistent_path_xyz_42\0");
    assert_true(e2 == false, 2);
    println("  [PASS] exists(nonexistent) -> false");
    passed += 1;

    // =========================================================================
    // Test 3: create_dir() on a new path → Result::Ok
    // =========================================================================
    // Clean up first in case previous run left it
    fs::remove_dir("/tmp/salt_test_dir_fs\0");

    let res3 = fs::create_dir("/tmp/salt_test_dir_fs\0");
    if res3.is_ok() {
        println("  [PASS] create_dir(\"/tmp/salt_test_dir_fs\") -> Ok");
        passed += 1;
    } else {
        println("  [FAIL] create_dir returned Err");
        failed += 1;
    }

    // =========================================================================
    // Test 4: create_dir() on existing path → Result::Err(already_exists)
    // =========================================================================
    let res4 = fs::create_dir("/tmp/salt_test_dir_fs\0");
    if res4.is_err() {
        let s = res4.status();
        assert_true(s.is_already_exists(), 4);
        println("  [PASS] create_dir(existing) -> Err(already_exists)");
        passed += 1;
    } else {
        println("  [FAIL] create_dir on existing should fail");
        failed += 1;
    }

    // =========================================================================
    // Test 5: exists() on the dir we just created → true
    // =========================================================================
    let e5 = fs::exists("/tmp/salt_test_dir_fs\0");
    assert_true(e5 == true, 5);
    println("  [PASS] exists(created dir) -> true");
    passed += 1;

    // =========================================================================
    // Test 6: remove_dir() on empty dir → Result::Ok
    // =========================================================================
    let res6 = fs::remove_dir("/tmp/salt_test_dir_fs\0");
    if res6.is_ok() {
        println("  [PASS] remove_dir(empty dir) -> Ok");
        passed += 1;
    } else {
        println("  [FAIL] remove_dir returned Err");
        failed += 1;
    }

    // =========================================================================
    // Test 7: exists() after removal → false
    // =========================================================================
    let e7 = fs::exists("/tmp/salt_test_dir_fs\0");
    assert_true(e7 == false, 7);
    println("  [PASS] exists(removed dir) -> false");
    passed += 1;

    // =========================================================================
    // Test 8: remove_dir() on nonexistent → Result::Err(not_found)
    // =========================================================================
    let res8 = fs::remove_dir("/tmp/salt_test_dir_fs\0");
    if res8.is_err() {
        let s8 = res8.status();
        assert_true(s8.is_not_found(), 8);
        println("  [PASS] remove_dir(nonexistent) -> Err(not_found)");
        passed += 1;
    } else {
        println("  [FAIL] remove_dir on nonexistent should fail");
        failed += 1;
    }

    // =========================================================================
    // Test 9: read_dir() on /tmp → count > 0
    // =========================================================================
    let res9 = fs::read_dir("/tmp\0");
    if res9.is_ok() {
        let mut iter = res9.unwrap();
        let mut count: i64 = 0;
        let name_buf = malloc(256);
        let mut name_len: i64 = 0;
        let mut is_dir: i32 = 0;

        while fs::dir_next(&mut iter, name_buf, 256, &mut name_len, &mut is_dir) {
            count += 1;
        }
        fs::dir_close(&mut iter);
        free(name_buf);

        assert_true(count > 0, 9);
        println(f"  [PASS] read_dir(\"/tmp\") -> {count} entries");
        passed += 1;
    } else {
        println("  [FAIL] read_dir returned Err");
        failed += 1;
    }

    // =========================================================================
    // Test 10: read_dir() on nonexistent → Result::Err(not_found)
    // =========================================================================
    let res10 = fs::read_dir("/tmp/salt_no_such_dir_xyz\0");
    if res10.is_err() {
        let s10 = res10.status();
        assert_true(s10.is_not_found(), 10);
        println("  [PASS] read_dir(nonexistent) -> Err(not_found)");
        passed += 1;
    } else {
        println("  [FAIL] read_dir on nonexistent should fail");
        failed += 1;
    }

    // =========================================================================
    // Summary
    // =========================================================================
    println("=== Summary ===");
    println(f"Passed: {passed}");
    println(f"Failed: {failed}");

    if failed == 0 {
        println("ALL FS TESTS PASSED");
    } else {
        println("SOME FS TESTS FAILED");
    }

    return failed as i32;
}
