// =============================================================================
// tests/lib/test_cross_module_struct.salt
// TDD End-to-End: Cross-module struct import
// =============================================================================
// Tests that imported struct types work in:
//   1. Function signatures (parameter and return types)
//   2. Struct literal construction
//   3. Cross-module function calls that accept/return structs

package main

import test.types.addr

// Local function using imported struct type in signature
fn double_phys(p: addr.PhysAddr) -> addr.PhysAddr {
    return addr.PhysAddr { val: p.val * 2 };
}

fn main() -> i32 {
    // T1: Construct imported struct directly
    let p = addr.PhysAddr { val: 0x1000 };
    if p.val != 0x1000 {
        return 1;
    }
    println("  [PASS] T1: construct imported PhysAddr");

    // T2: Use imported struct in local function signature
    let doubled = double_phys(p);
    if doubled.val != 0x2000 {
        return 2;
    }
    println("  [PASS] T2: imported struct in local function signature");

    // T3: Call imported function that returns imported struct
    let p2 = addr.make_phys(0x3000);
    if p2.val != 0x3000 {
        return 3;
    }
    println("  [PASS] T3: imported function returning imported struct");

    // T4: Call imported function that takes imported struct as parameter
    let v = addr.phys_to_virt(p);
    if v.val != 0xFFFFFFFF80001000 {
        return 4;
    }
    println("  [PASS] T4: imported function accepting imported struct");

    println("=== all cross-module struct tests passed ===");
    return 0;
}
