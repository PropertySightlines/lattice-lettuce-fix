// Test: Extern fn declarations take priority over wildcard imports
// Validates that `extern fn enable_interrupts()` in the local file
// is resolved correctly even when `use kernel.core.scheduler` is imported.
//
// This is a lib-mode test — should compile MLIR without errors.

package test.extern_priority

use kernel.core.scheduler

extern fn enable_interrupts();
extern fn rdtsc() -> i64;

pub fn test_extern_call() {
    enable_interrupts();
    let t = rdtsc();
}
