// =============================================================================
// tests/lib/test_typed_addr_loop.salt
// TDD: Typed PhysAddr/VirtAddr construction inside loops
// =============================================================================
// Proves that LLVM's SROA pass eliminates single-field struct wrappers.
// PhysAddr/VirtAddr constructed in tight loops must compile and execute
// identically to raw u64 arithmetic.
//
// This test validates the kernel refactor: ALL phys_to_virt_raw() calls
// can safely be replaced with typed phys_to_virt(PhysAddr { val: ... }).

package main

import test.types.addr

// Simulates PMM page-walk: construct PhysAddr in a loop, convert, accumulate
fn sum_virt_pages(start: u64, count: u64) -> u64 {
    let mut total: u64 = 0;
    let mut i: u64 = 0;
    let page_size: u64 = 4096;

    while i < count {
        // Inner loop struct construction — SROA eliminates this
        let phys = addr.PhysAddr { val: start + i * page_size };
        let virt = addr.phys_to_virt(phys);
        total = total + virt.val;
        i = i + 1;
    }
    return total;
}

// Simulates kernel stack allocation with typed API
fn alloc_and_convert(base_phys: u64) -> addr.VirtAddr {
    let p = addr.PhysAddr { val: base_phys };
    return addr.phys_to_virt(p);
}

fn main() -> i32 {
    // T1: Single typed conversion (baseline)
    let p = addr.PhysAddr { val: 0x1000 };
    let v = addr.phys_to_virt(p);
    if v.val != 0xFFFFFFFF80001000 {
        return 1;
    }
    println("  [PASS] T1: single typed conversion");

    // T2: Typed construction in loop (PMM hot-path pattern)
    // 4 pages starting at 0x1000: virt = phys + 0xFFFFFFFF80000000
    // sum = (0xFFFFFFFF80001000) + (0xFFFFFFFF80002000) + (0xFFFFFFFF80003000) + (0xFFFFFFFF80004000)
    let sum = sum_virt_pages(0x1000, 4);
    let expected: u64 = 0xFFFFFFFF80001000 + 0xFFFFFFFF80002000 + 0xFFFFFFFF80003000 + 0xFFFFFFFF80004000;
    if sum != expected {
        return 2;
    }
    println("  [PASS] T2: typed struct construction in loop");

    // T3: Function returning typed VirtAddr (kernel stack pattern)
    let kstack_virt = alloc_and_convert(0x200000);
    if kstack_virt.val != 0xFFFFFFFF80200000 {
        return 3;
    }
    println("  [PASS] T3: function returning typed VirtAddr");

    // T4: Chained typed operations (double conversion)
    let phys1 = addr.PhysAddr { val: 0x5000 };
    let virt1 = addr.phys_to_virt(phys1);
    let phys2 = addr.PhysAddr { val: virt1.val - 0xFFFFFFFF80000000 };
    if phys2.val != 0x5000 {
        return 4;
    }
    println("  [PASS] T4: chained typed operations");

    println("=== all typed address loop tests passed ===");
    return 0;
}
