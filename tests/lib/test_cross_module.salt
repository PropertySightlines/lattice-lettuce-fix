// Test: Cross-module calls in lib mode emit external declarations
// instead of hydrating the function body. This prevents failures
// from missing module globals (e.g., GLOBAL_SCHED in scheduler).
//
// Validates that module.method() calls across packages compile
// without trying to inline the remote function body.

package test.cross_module

use kernel.core.scheduler
use kernel.drivers.serial

pub fn test_cross_call() {
    // These should emit func.call @kernel__core__scheduler__spawn(...)
    // NOT hydrate the scheduler's spawn() body (which references GLOBAL_SCHED).
    scheduler.spawn(0);
    
    // Similarly for serial — should not hydrate serial.init() body.
    serial.init();
}
