// =============================================================================
// Test: std.nn.loss — softmax_cross_entropy_grad
// =============================================================================

package main

extern fn malloc(size: i64) -> Ptr<u8>;
extern fn expf(x: f32) -> f32;

// Functions under test: softmax_cross_entropy_grad
// This is a compiler intrinsic (std.nn)

fn alloc_f32(count: i64) -> Ptr<f32> {
    let ptr: Ptr<u8> = malloc(count * 4);
    return ptr as Ptr<f32>;
}

fn approx_eq(a: f32, b: f32, tol: f32) -> bool {
    let diff = a - b;
    let abs_diff = if diff > 0.0f32 { diff } else { 0.0f32 - diff };
    return abs_diff < tol;
}

fn main() -> i32 {
    // 3-class logits: [2.0, 1.0, 0.1], label = 0
    let output = alloc_f32(3);
    output[0] = 2.0f32;
    output[1] = 1.0f32;
    output[2] = 0.1f32;

    let delta = alloc_f32(3);

    softmax_cross_entropy_grad(output, delta, 3, 0);

    // softmax([2.0, 1.0, 0.1]) ≈ [0.659, 0.242, 0.099]
    // gradient = softmax - one_hot(0) ≈ [-0.341, 0.242, 0.099]

    // Check correct class has negative gradient
    if delta[0] >= 0.0f32 { return 1; }

    // Check wrong classes have positive gradient
    if delta[1] <= 0.0f32 { return 2; }
    if delta[2] <= 0.0f32 { return 3; }

    // Check approximate values
    if !approx_eq(delta[0], -0.341f32, 0.02f32) { return 4; }
    if !approx_eq(delta[1], 0.242f32, 0.02f32) { return 5; }
    if !approx_eq(delta[2], 0.099f32, 0.02f32) { return 6; }

    // Gradient should sum to approximately 0.0
    let grad_sum = delta[0] + delta[1] + delta[2];
    if !approx_eq(grad_sum, 0.0f32, 0.01f32) { return 7; }

    // Test 2: label = 2 (last class)
    output[0] = 1.0f32;
    output[1] = 1.0f32;
    output[2] = 1.0f32;

    softmax_cross_entropy_grad(output, delta, 3, 2);

    // Equal logits → softmax = [1/3, 1/3, 1/3]
    // gradient for class 2 = 1/3 - 1 ≈ -0.667
    if delta[2] >= 0.0f32 { return 10; }
    if !approx_eq(delta[2], -0.667f32, 0.02f32) { return 11; }
    // Others ≈ 0.333
    if !approx_eq(delta[0], 0.333f32, 0.02f32) { return 12; }
    if !approx_eq(delta[1], 0.333f32, 0.02f32) { return 13; }

    println("nn loss: PASS");
    return 0;
}
