// Phase 6 ADT Smoke Test
// Validates Option<T> and Result<T, E> end-to-end:
// - Enum construction (Some, None, Ok, Err)
// - Method dispatch (is_some, is_none, unwrap, unwrap_or, is_ok, is_err, unwrap_err)
// - Generic monomorphization with i64 payloads
package main

import std.core.option.Option
import std.core.result.Result

pub fn main() -> i32 {
    let mut failures = 0;

    // --- Option<i64> Tests ---
    println("=== Option<i64> Tests ===");

    let some_val = Option<i64>::Some(42);
    let none_val = Option<i64>::None;

    // Test is_some / is_none
    if some_val.is_some() {
        println("PASS: Some(42).is_some() == true");
    } else {
        println("FAIL: Some(42).is_some() == false");
        failures = failures + 1;
    }

    if none_val.is_none() {
        println("PASS: None.is_none() == true");
    } else {
        println("FAIL: None.is_none() == false");
        failures = failures + 1;
    }

    // Test unwrap
    let val = some_val.unwrap();
    if val == 42 {
        println("PASS: Some(42).unwrap() == 42");
    } else {
        println("FAIL: Some(42).unwrap() != 42");
        failures = failures + 1;
    }

    // Test unwrap_or
    let val2 = none_val.unwrap_or(99);
    if val2 == 99 {
        println("PASS: None.unwrap_or(99) == 99");
    } else {
        println("FAIL: None.unwrap_or(99) != 99");
        failures = failures + 1;
    }

    // --- Result<i64, i64> Tests ---
    println("\n=== Result<i64, i64> Tests ===");

    let ok_res = Result<i64, i64>::Ok(100);
    let err_res = Result<i64, i64>::Err(77);

    // Test is_ok / is_err
    if ok_res.is_ok() {
        println("PASS: Ok(100).is_ok() == true");
    } else {
        println("FAIL: Ok(100).is_ok() == false");
        failures = failures + 1;
    }

    if err_res.is_err() {
        println("PASS: Err(77).is_err() == true");
    } else {
        println("FAIL: Err(77).is_err() == false");
        failures = failures + 1;
    }

    // Test unwrap on Ok
    let ok_val = ok_res.unwrap();
    if ok_val == 100 {
        println("PASS: Ok(100).unwrap() == 1");
    } else {
        println("FAIL: Ok(100).unwrap() != 1");
        failures = failures + 1;
    }

    // Test unwrap_err on Err
    let err_val = err_res.unwrap_err();
    if err_val == 77 {
        println("PASS: Err(77).unwrap_err() == 77");
    } else {
        println("FAIL: Err(77).unwrap_err() != 77");
        failures = failures + 1;
    }

    // Test unwrap_or on Err
    let or_val = err_res.unwrap_or(999);
    if or_val == 999 {
        println("PASS: Err(77).unwrap_or(999) == 999");
    } else {
        println("FAIL: Err(77).unwrap_or(999) != 999");
        failures = failures + 1;
    }

    // --- Summary ---
    if failures == 0 {
        println("\n=== ALL TESTS PASSED ===");
    } else {
        println("\n=== SOME TESTS FAILED ===");
    }

    return failures;
}
