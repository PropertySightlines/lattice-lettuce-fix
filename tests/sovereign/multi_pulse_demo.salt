// Multi-Pulse Demo: Coexisting Frequencies
//
// This test demonstrates two pulse functions running at different frequencies:
// - sensor_ingest @ 1000Hz (real-time tier 0)
// - update_ui @ 60Hz (interactive tier 1)
//
// The scheduler ensures the 1000Hz pulse is never starved by the 60Hz pulse.

use std::core::sovereign::context
use std::core::sovereign::executor
use std::core::sovereign::arena

// Shared state between pulses
struct SensorData {
    gyro_x: f32,
    gyro_y: f32,
    gyro_z: f32,
    timestamp: i64,
}

struct SharedBuffer {
    data: [SensorData; 128],
    write_idx: i64,
    read_idx: i64,
}

impl SharedBuffer {
    fn new() -> SharedBuffer {
        SharedBuffer {
            data: [SensorData { gyro_x: 0.0, gyro_y: 0.0, gyro_z: 0.0, timestamp: 0 }; 128],
            write_idx: 0,
            read_idx: 0,
        }
    }
    
    fn push(self, reading: SensorData) {
        let idx = self.write_idx % 128
        self.data[idx] = reading
        self.write_idx = self.write_idx + 1
    }
    
    fn pop(self) -> SensorData {
        if self.read_idx >= self.write_idx {
            return SensorData { gyro_x: 0.0, gyro_y: 0.0, gyro_z: 0.0, timestamp: 0 }
        }
        let idx = self.read_idx % 128
        self.read_idx = self.read_idx + 1
        self.data[idx]
    }
    
    fn len(self) -> i64 {
        self.write_idx - self.read_idx
    }
}

// Global buffer (in real use, would use Mutex for thread safety)
global BUFFER: SharedBuffer = SharedBuffer::new()

// High-frequency sensor polling (1000Hz = 1ms intervals)
// Priority Tier 0 - pinned to performance cores
@pulse(1000)
fn sensor_ingest() {
    // Simulate reading from gyroscope
    let reading = SensorData {
        gyro_x: 0.1,
        gyro_y: -0.05,
        gyro_z: 0.02,
        timestamp: context::now(),
    }
    
    // Push to shared buffer
    BUFFER.push(reading)
    
    // Check deadline - yield if time budget exceeded
    // (In full integration, this is auto-injected by yield_injection pass)
    context::check_deadline()
}

// UI update at 60Hz - heavier workload
// Priority Tier 1 - work-stealing across cores
@pulse(60)
fn update_ui() {
    // Process all available sensor data
    let processed_count = 0
    
    while BUFFER.len() > 0 {
        let data = BUFFER.pop()
        
        // Simulate physics calculation
        let force_x = data.gyro_x * 9.81
        let force_y = data.gyro_y * 9.81
        let force_z = data.gyro_z * 9.81
        
        processed_count = processed_count + 1
        
        // Yield check at loop back-edge (auto-injected)
        context::check_deadline()
    }
    
    // Log how many readings we processed this frame
    println("Processed {} sensor readings", processed_count)
}

// Background task for telemetry (10Hz)
// Priority Tier 2 - efficiency cores
@pulse(10)
fn telemetry_upload() {
    // Simulated network I/O (would be async in real implementation)
    println("Uploading telemetry...")
}

// Entry point
fn main() -> i32 {
    println("=== Multi-Pulse Demo ===")
    println("Starting executor with 3 pulses:")
    println("  - sensor_ingest @ 1000Hz (Tier 0)")
    println("  - update_ui @ 60Hz (Tier 1)")
    println("  - telemetry_upload @ 10Hz (Tier 2)")
    
    // In full implementation, would start the Sovereign Executor here
    // executor::start()
    
    // For now, simulate a few iterations
    for i in 0..10 {
        sensor_ingest()
        
        if i % 16 == 0 {
            update_ui()
        }
        if i % 100 == 0 {
            telemetry_upload()
        }
    }
    
    println("Demo complete.")
    0
}
