// =============================================================================
// String ↔ StringView Conversion Tests
// =============================================================================
// Verifies:
//   1. String::as_view() returns correct ptr/len (zero-copy)
//   2. String::from_view() creates independent copy
//   3. Round-trip: String → StringView → String preserves content
//   4. Empty string edge cases
//   5. "hello" as StringView literal cast (NEW COMPILER INTRINSIC)

package main

use std.core.ptr.Ptr
use std.core.str.StringView
use std.string.String

extern fn exit(code: i32);

fn assert_eq(got: i64, expected: i64, test_id: i32) {
    if got != expected {
        println(f"FAIL test {test_id}: got {got}, expected {expected}");
        exit(test_id);
    }
}

fn main() -> i32 {
    // =========================================================================
    // Test 1: String::as_view() returns correct length
    // =========================================================================
    let mut s1 = String::with_capacity(16);
    s1.push_byte(72);  // H
    s1.push_byte(105); // i
    let view1 = s1.as_view();
    assert_eq(view1.length(), 2, 1);
    println("  [PASS] as_view() returns correct length");

    // =========================================================================
    // Test 2: StringView points to same data (zero-copy)
    // =========================================================================
    let view_byte = view1.byte_at(0);
    assert_eq(view_byte as i64, 72, 2);  // 'H'
    let view_byte2 = view1.byte_at(1);
    assert_eq(view_byte2 as i64, 105, 2);  // 'i'
    println("  [PASS] as_view() is zero-copy (same bytes)");

    // =========================================================================
    // Test 3: String::from_view() creates a copy with correct content
    // =========================================================================
    let s2 = String::from_view(&view1);
    assert_eq(s2.len(), 2, 3);
    assert_eq(s2.byte_at(0) as i64, 72, 3);   // 'H'
    assert_eq(s2.byte_at(1) as i64, 105, 3);   // 'i'
    println("  [PASS] from_view() creates copy with correct content");

    // =========================================================================
    // Test 4: from_view() copy is independent (different pointer)
    // =========================================================================
    assert_eq(s2.capacity() as i64, 2, 4);
    println("  [PASS] from_view() copy is independent allocation");

    // =========================================================================
    // Test 5: Empty string round-trip
    // =========================================================================
    let empty = String::new();
    let empty_view = empty.as_view();
    assert_eq(empty_view.length(), 0, 5);
    let empty_copy = String::from_view(&empty_view);
    assert_eq(empty_copy.len(), 0, 5);
    println("  [PASS] empty string round-trip works");

    // =========================================================================
    // Test 6: StringView::from_raw with literal, then from_view
    // =========================================================================
    let lit_view = StringView::from_raw("hello" as Ptr<u8>, 5);
    let lit_string = String::from_view(&lit_view);
    assert_eq(lit_string.len(), 5, 6);
    assert_eq(lit_string.byte_at(0) as i64, 104, 6); // 'h'
    assert_eq(lit_string.byte_at(4) as i64, 111, 6); // 'o'
    println("  [PASS] literal → StringView → String round-trip");

    // =========================================================================
    // Test 7: "hello" as StringView — compiler intrinsic!
    // =========================================================================
    let sv = "hello" as StringView;
    assert_eq(sv.length(), 5, 7);
    assert_eq(sv.byte_at(0) as i64, 104, 7);  // 'h'
    assert_eq(sv.byte_at(1) as i64, 101, 7);  // 'e'
    assert_eq(sv.byte_at(2) as i64, 108, 7);  // 'l'
    assert_eq(sv.byte_at(3) as i64, 108, 7);  // 'l'
    assert_eq(sv.byte_at(4) as i64, 111, 7);  // 'o'
    println("  [PASS] \"hello\" as StringView — compiler intrinsic");

    // =========================================================================
    // Test 8: Empty literal as StringView
    // =========================================================================
    let empty_sv = "" as StringView;
    assert_eq(empty_sv.length(), 0, 8);
    println("  [PASS] \"\" as StringView — empty literal");

    // =========================================================================
    // Test 9: Longer string preserves all bytes
    // =========================================================================
    let long_sv = "Hello, Salt!" as StringView;
    assert_eq(long_sv.length(), 12, 9);
    assert_eq(long_sv.byte_at(0) as i64, 72, 9);   // 'H'
    assert_eq(long_sv.byte_at(11) as i64, 33, 9);  // '!'
    println("  [PASS] \"Hello, Salt!\" as StringView — correct length and bytes");

    println("=== all string conversion tests passed ===");
    return 0;
}
