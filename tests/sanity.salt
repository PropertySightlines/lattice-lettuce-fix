// This file must verify successfully AND run successfully

fn safe_add(a: i32, b: i32) -> i32 
    ensures(result >= a) 
{
    return a + b
}

fn main() {
    test("math sanity", {
        res = safe_add(10, 20)
        assert_eq(res, 30)
    })
    
    test("logic sanity", {
        assert(true)
    })
}
