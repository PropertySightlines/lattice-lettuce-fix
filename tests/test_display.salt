// test_display.salt - TDD test for Display trait integration with println
// Tests that println("{}", x) dispatches through Display::fmt for structs

package test_display

use std.string.String
use std.fmt.Display

// ============================================================================
// Test 1: A struct with manual Display implementation
// ============================================================================
struct Point {
    x: i64,
    y: i64,
}

impl Display for Point {
    fn fmt(&self, buf: &mut String) {
        buf.push_ascii(40);  // '('
        self.x.fmt(buf);
        buf.push_cstr(", \0");
        self.y.fmt(buf);
        buf.push_ascii(41);  // ')'
    }
}

// ============================================================================
// Test 2: Nested struct with Display  
// ============================================================================
struct Line {
    start: Point,
    end: Point,
}

impl Display for Line {
    fn fmt(&self, buf: &mut String) {
        self.start.fmt(buf);
        buf.push_cstr(" -> \0");
        self.end.fmt(buf);
    }
}

fn main() -> i32 {
    // Test 1: Primitive Display (uses fast C runtime path)
    println("=== Display Trait Tests ===");
    println("i64: {}", 42);
    println("f64: {}", 3.14);
    println("bool: {}", true);

    // Test 2: Struct with manual Display
    let p = Point { x: 10, y: 20 };
    println("Point: {}", p);

    // Test 3: Nested struct Display
    let line = Line {
        start: Point { x: 0, y: 0 },
        end: Point { x: 100, y: 200 },
    };
    println("Line: {}", line);

    println("=== All Display tests passed ===");
    return 0;
}
