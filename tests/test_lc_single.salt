// test_lc_single.salt - Single round for timing analysis
package main
use std.collections.hash_map.HashMap

extern fn malloc(size: i64) -> u64;
extern fn free(ptr: u64);

fn read_i64(base: u64, idx: i64) -> i64 {
    let ptr = reinterpret_cast::<&i64>(base + (idx * 8) as u64);
    return *ptr;
}

fn write_i64(base: u64, idx: i64, val: i64) {
    let ptr = reinterpret_cast::<&mut i64>(base + (idx * 8) as u64);
    *ptr = val;
}

fn main() -> i32 {
    let n: i64 = 10000;  // Smaller: 10K instead of 100K
    let nums = malloc(n * 8);
    
    // SINGLE ROUND - measure one iteration time
    let mut i: i64 = 0;
    while i < n {
        write_i64(nums, i, (i * 1103515245 + 12345) % (n * 10));
        i = i + 1;
    }
    
    println(f"Creating HashMap with capacity {n}...");
    let mut set = HashMap<i64, i64>::with_capacity(n);
    
    println(f"Inserting {n} items...");
    i = 0;
    while i < n {
        set.insert(read_i64(nums, i), 1);
        i = i + 1;
    }
    
    println("Finding longest sequence...");
    let mut best: i64 = 0;
    i = 0;
    while i < n {
        let num = read_i64(nums, i);
        let prev = num - 1;
        if set.get(&prev) == 0 {
            let mut len: i64 = 1;
            let mut next = num + len;
            while set.get(&next) != 0 {
                len = len + 1;
                next = num + len;
            }
            if len > best { best = len; }
        }
        i = i + 1;
    }
    
    println(f"Best: {best}");
    set.drop();
    free(nums);
    return 0;
}
