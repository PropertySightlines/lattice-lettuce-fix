
package main

extern fn alloc(bytes: u64) -> u64;

@no_mangle
fn main_salt() -> i32 {
    println("Testing V6 Sovereign Vector Intrinsics...");
    
    // Allocate aligned buffer for 16 floats
    let buf: &f32 = reinterpret_cast(alloc(64));
    
    // Initialize with 0.0, 1.0, 2.0, ... 15.0
    for i in 0..16 {
        let idx = i as i32;
        let ptr = buf + idx;
        *ptr = idx as f32;
    }
    
    // Test vector_load: Load first 8 floats
    let v1 = vector_load(buf);
    
    // Test vector_splat: Create vector of 2.0
    let two: f32 = 2.0 as f32;
    let v_two = vector_splat(two);
    
    // Test vector_fma: v1 * v_two + v_two = [2, 4, 6, 8, 10, 12, 14, 16]
    let v_result = vector_fma(v1, v_two, v_two);
    
    // Test vector_reduce_add: Sum all lanes
    // Expected: 2 + 4 + 6 + 8 + 10 + 12 + 14 + 16 = 72
    let sum = vector_reduce_add(v_result);
    
    println(f"FMA result reduced: {sum} (expected 72.0)");
    
    // Test vector_store: Store v_result to second half of buffer
    vector_store(buf + 8, v_result);
    
    // Verify stored values
    print("Stored values: ");
    for i in 8..16 {
        let val = *(buf + (i as i32));
        print(f"{val} ");
    }
    println("");
    
    if sum > 71.9 && sum < 72.1 {
        println("V6 Vector Intrinsics Test PASSED!");
    } else {
        println("V6 Vector Intrinsics Test FAILED!");
    }
    
    return 0;
}
