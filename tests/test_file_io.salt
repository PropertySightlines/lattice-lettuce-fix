// I/O Renaissance — TDD Tests
// Tests File::read, File::write, File::write_all, BufferedReader

use std.io.file.File
use std.io.file.OpenFlags
use std.io.file.O_RDONLY
use std.io.file.O_WRONLY
use std.io.file.O_CREAT
use std.io.file.O_TRUNC
use std.io.buffered_reader.BufferedReader
use std.core.ptr.Ptr

extern fn malloc(size: i64) -> Ptr<u8>;
extern fn free(ptr: Ptr<u8>);

fn main() -> i32 {
    let mut passed: i64 = 0;
    let mut failed: i64 = 0;

    println("=== I/O Renaissance Tests ===");

    // =========================================================================
    // Section 1: File Write
    // =========================================================================
    println("--- Section 1: File::write_all ---");

    let flags_w = O_WRONLY.or(O_CREAT).or(O_TRUNC);
    let res = File::open("/tmp/salt_io_test.txt\0", flags_w);

    if res.is_err() {
        println("FATAL: could not open file for writing");
        return 1;
    }

    let file = res.unwrap();

    // Write "Hello\nWorld\n" = 12 bytes
    let write_res = file.write_all("Hello\nWorld\n\0", 12);

    if write_res.is_err() {
        println("FAIL: write_all returned error");
        failed += 1;
    } else {
        let written = write_res.unwrap();
        print("write_all returned 12 bytes");
        if written == 12 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }
    }

    file.close();

    // =========================================================================
    // Section 2: File Read (raw)
    // =========================================================================
    println("--- Section 2: File::read ---");

    let res2 = File::open("/tmp/salt_io_test.txt\0", O_RDONLY);
    if res2.is_err() {
        println("FATAL: could not open file for reading");
        return 1;
    }

    let file2 = res2.unwrap();
    let buf = malloc(64);

    let read_res = file2.read(buf, 64);
    if read_res.is_err() {
        println("FAIL: read returned error");
        failed += 1;
    } else {
        let bytes_read = read_res.unwrap();

        // Should have read exactly 12 bytes
        print("read returned 12 bytes");
        if bytes_read == 12 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

        // First byte is 'H' (72)
        let b0 = intrin::ptr_read_at(buf, 0);
        print("buf[0] == 'H' (72)");
        if b0 == 72 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

        // Byte 5 is '\n' (10)
        let b5 = intrin::ptr_read_at(buf, 5);
        print("buf[5] == newline (10)");
        if b5 == 10 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

        // Byte 6 is 'W' (87)
        let b6 = intrin::ptr_read_at(buf, 6);
        print("buf[6] == 'W' (87)");
        if b6 == 87 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

        // Byte 11 is '\n' (10)
        let b11 = intrin::ptr_read_at(buf, 11);
        print("buf[11] == newline (10)");
        if b11 == 10 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }
    }

    free(buf);
    file2.close();

    // =========================================================================
    // Section 3: File::write (single call)
    // =========================================================================
    println("--- Section 3: File::write ---");

    let flags_w2 = O_WRONLY.or(O_CREAT).or(O_TRUNC);
    let res3 = File::open("/tmp/salt_io_test2.txt\0", flags_w2);
    if res3.is_err() {
        println("FATAL: could not open file2 for writing");
        return 1;
    }

    let file3 = res3.unwrap();
    let w1 = file3.write("ABC\0", 3);

    if w1.is_err() {
        println("FAIL: write returned error");
        failed += 1;
    } else {
        let n = w1.unwrap();
        print("write('ABC') returned 3");
        if n == 3 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }
    }

    file3.close();

    // Verify by reading back
    let res4 = File::open("/tmp/salt_io_test2.txt\0", O_RDONLY);
    if res4.is_err() {
        println("FATAL: could not open file2 for reading");
        return 1;
    }

    let file4 = res4.unwrap();
    let buf2 = malloc(16);
    let read_res2 = file4.read(buf2, 16);

    if read_res2.is_err() {
        println("FAIL: read back failed");
        failed += 1;
    } else {
        let n = read_res2.unwrap();
        print("readback got 3 bytes");
        if n == 3 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

        let c0 = intrin::ptr_read_at(buf2, 0);
        print("readback[0] == 'A' (65)");
        if c0 == 65 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }
    }

    free(buf2);
    file4.close();

    // =========================================================================
    // Section 4: BufferedReader — read_line
    // =========================================================================
    println("--- Section 4: BufferedReader::read_line ---");

    let res5 = File::open("/tmp/salt_io_test.txt\0", O_RDONLY);
    if res5.is_err() {
        println("FATAL: could not open file for BufferedReader");
        return 1;
    }

    let mut reader = BufferedReader::new(res5.unwrap().fd());
    let line_buf = malloc(128);

    // Line 1: "Hello\n" = 6 bytes
    let len1 = reader.read_line(line_buf, 128);
    print("line1 length == 6");
    if len1 == 6 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    let l1b0 = intrin::ptr_read_at(line_buf, 0);
    print("line1[0] == 'H' (72)");
    if l1b0 == 72 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    let l1b5 = intrin::ptr_read_at(line_buf, 5);
    print("line1[5] == newline (10)");
    if l1b5 == 10 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    // Line 2: "World\n" = 6 bytes
    let len2 = reader.read_line(line_buf, 128);
    print("line2 length == 6");
    if len2 == 6 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    let l2b0 = intrin::ptr_read_at(line_buf, 0);
    print("line2[0] == 'W' (87)");
    if l2b0 == 87 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    // Line 3: EOF — should return 0
    let len3 = reader.read_line(line_buf, 128);
    print("line3 (EOF) length == 0");
    if len3 == 0 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    free(line_buf);
    reader.close();

    // =========================================================================
    // Section 5: BufferedReader — read_byte
    // =========================================================================
    println("--- Section 5: BufferedReader::read_byte ---");

    let res6 = File::open("/tmp/salt_io_test2.txt\0", O_RDONLY);
    if res6.is_err() {
        println("FATAL: could not open file for read_byte");
        return 1;
    }

    let mut reader2 = BufferedReader::new(res6.unwrap().fd());

    let b1 = reader2.read_byte();
    print("byte1 == 'A' (65)");
    if b1 == 65 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    let b2 = reader2.read_byte();
    print("byte2 == 'B' (66)");
    if b2 == 66 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    let b3 = reader2.read_byte();
    print("byte3 == 'C' (67)");
    if b3 == 67 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    // EOF
    let b4 = reader2.read_byte();
    print("byte4 (EOF) == -1");
    if b4 == -1 { println("  ... PASS"); passed += 1; } else { println("  ... FAIL"); failed += 1; }

    reader2.close();

    // =========================================================================
    // Summary
    // =========================================================================
    println("=== Summary ===");
    println(f"Passed: {passed}");
    println(f"Failed: {failed}");

    if failed == 0 {
        println("ALL TESTS PASSED");
    } else {
        println("SOME TESTS FAILED");
    }

    return failed as i32;
}
