// =============================================================================
// tests/test_eth_parse_build.salt
// Ethernet Frame Parse/Build Round-Trip — Unit Test
// =============================================================================
//
// Verifies the byte-level Ethernet II frame contract:
//   [6B dst MAC][6B src MAC][2B EtherType (big-endian)][payload...]
//
// These are the same algorithms used by kernel/net/eth.salt, copied here
// as self-contained specification tests that run in userspace with no
// kernel or hardware dependencies.
// =============================================================================

package main

use std.core.ptr.Ptr

extern fn puts(s: Ptr<u8>) -> i32;
extern fn malloc(size: i64) -> u64;
extern fn free(ptr: u64);
extern fn exit(code: i32);

// --- Pure functions under test (mirror of kernel/net/eth.salt) ---------------

struct EthernetHeader {
    dst: [u8; 6],
    src: [u8; 6],
    ethertype: u16,
}

fn eth_parse(buf: u64, len: u32) -> EthernetHeader {
    let mut hdr = EthernetHeader {
        dst: [0 as u8; 6],
        src: [0 as u8; 6],
        ethertype: 0,
    };

    if len < 14 {
        return hdr;
    }

    let mut i: u32 = 0;
    while i < 6 {
        hdr.dst[i] = *((buf + i as u64) as &u8);
        i = i + 1;
    }

    let mut j: u32 = 0;
    while j < 6 {
        hdr.src[j] = *((buf + 6 + j as u64) as &u8);
        j = j + 1;
    }

    let hi = *((buf + 12) as &u8) as u16;
    let lo = *((buf + 13) as &u8) as u16;
    hdr.ethertype = (hi << 8) | lo;

    return hdr;
}

fn eth_build(buf: u64, dst: [u8; 6], src: [u8; 6], ethertype: u16) -> u32 {
    let mut i: u32 = 0;
    while i < 6 {
        *((buf + i as u64) as &mut u8) = dst[i];
        i = i + 1;
    }

    let mut j: u32 = 0;
    while j < 6 {
        *((buf + 6 + j as u64) as &mut u8) = src[j];
        j = j + 1;
    }

    *((buf + 12) as &mut u8) = (ethertype >> 8) as u8;
    *((buf + 13) as &mut u8) = (ethertype & 0xFF) as u8;

    return 14;
}

fn mac_matches(a: [u8; 6], b: [u8; 6]) -> bool {
    let mut i: u32 = 0;
    while i < 6 {
        if a[i] != b[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn is_broadcast(mac: [u8; 6]) -> bool {
    let mut i: u32 = 0;
    while i < 6 {
        if mac[i] != 0xFF {
            return false;
        }
        i = i + 1;
    }
    return true;
}

// --- Test helpers -----------------------------------------------------------

fn fail(msg: Ptr<u8>) {
    puts(msg);
    exit(1);
}

// --- Tests ------------------------------------------------------------------

fn main() -> i32 {
    let buf = malloc(64);
    if buf == 0 {
        fail("FAIL: malloc returned null" as Ptr<u8>);
        return 1;
    }

    // Zero the buffer
    let mut z: i32 = 0;
    while z < 64 {
        *((buf + z as u64) as &mut u8) = 0;
        z = z + 1;
    }

    // ---- Test 1: Build→Parse round-trip ------------------------------------
    let dst: [u8; 6] = [0xAA as u8, 0xBB as u8, 0xCC as u8, 0xDD as u8, 0xEE as u8, 0xFF as u8];
    let src: [u8; 6] = [0x11 as u8, 0x22 as u8, 0x33 as u8, 0x44 as u8, 0x55 as u8, 0x66 as u8];
    let ethertype: u16 = 0x0800;

    let sz = eth_build(buf, dst, src, ethertype);
    if sz != 14 {
        fail("FAIL: eth_build did not return 14" as Ptr<u8>);
    }

    let hdr = eth_parse(buf, 14);

    // Copy struct array fields to locals (Salt struct fields return references)
    let mut parsed_dst: [u8; 6] = [0 as u8; 6];
    let mut parsed_src: [u8; 6] = [0 as u8; 6];
    let mut ci: u32 = 0;
    while ci < 6 {
        parsed_dst[ci] = hdr.dst[ci];
        parsed_src[ci] = hdr.src[ci];
        ci = ci + 1;
    }

    if !mac_matches(parsed_dst, dst) {
        fail("FAIL: parsed dst MAC mismatch" as Ptr<u8>);
    }
    if !mac_matches(parsed_src, src) {
        fail("FAIL: parsed src MAC mismatch" as Ptr<u8>);
    }
    if hdr.ethertype != 0x0800 {
        fail("FAIL: parsed ethertype mismatch" as Ptr<u8>);
    }

    // ---- Test 2: Broadcast detection ---------------------------------------
    let bcast: [u8; 6] = [0xFF as u8, 0xFF as u8, 0xFF as u8, 0xFF as u8, 0xFF as u8, 0xFF as u8];
    eth_build(buf, bcast, src, 0x0806);
    let hdr2 = eth_parse(buf, 14);

    let mut parsed_dst2: [u8; 6] = [0 as u8; 6];
    let mut ci2: u32 = 0;
    while ci2 < 6 {
        parsed_dst2[ci2] = hdr2.dst[ci2];
        ci2 = ci2 + 1;
    }
    if !is_broadcast(parsed_dst2) {
        fail("FAIL: broadcast not detected" as Ptr<u8>);
    }

    // ---- Test 3: MAC matching (positive + negative) ------------------------
    let mac_a: [u8; 6] = [0x01 as u8, 0x02 as u8, 0x03 as u8, 0x04 as u8, 0x05 as u8, 0x06 as u8];
    let mac_b: [u8; 6] = [0x01 as u8, 0x02 as u8, 0x03 as u8, 0x04 as u8, 0x05 as u8, 0x06 as u8];
    let mac_c: [u8; 6] = [0x01 as u8, 0x02 as u8, 0x03 as u8, 0x04 as u8, 0x05 as u8, 0x07 as u8];

    if !mac_matches(mac_a, mac_b) {
        fail("FAIL: identical MACs should match" as Ptr<u8>);
    }
    if mac_matches(mac_a, mac_c) {
        fail("FAIL: different MACs should not match" as Ptr<u8>);
    }

    // ---- Test 4: Short frame rejection -------------------------------------
    let hdr3 = eth_parse(buf, 13);
    if hdr3.ethertype != 0 {
        fail("FAIL: short frame should return zeroed header" as Ptr<u8>);
    }

    // ---- Test 5: Big-endian EtherType encoding -----------------------------
    // Build ARP frame (0x0806)
    eth_build(buf, dst, src, 0x0806);
    let byte12 = *((buf + 12) as &u8);
    let byte13 = *((buf + 13) as &u8);
    if byte12 != 0x08 {
        fail("FAIL: ARP ethertype byte12 != 0x08" as Ptr<u8>);
    }
    if byte13 != 0x06 {
        fail("FAIL: ARP ethertype byte13 != 0x06" as Ptr<u8>);
    }

    // Build IPv4 frame (0x0800)
    eth_build(buf, dst, src, 0x0800);
    let byte12b = *((buf + 12) as &u8);
    let byte13b = *((buf + 13) as &u8);
    if byte12b != 0x08 {
        fail("FAIL: IPv4 ethertype byte12 != 0x08" as Ptr<u8>);
    }
    if byte13b != 0x00 {
        fail("FAIL: IPv4 ethertype byte13 != 0x00" as Ptr<u8>);
    }

    free(buf);
    puts("PASS: all eth tests" as Ptr<u8>);
    return 0;
}
