// =============================================================================
// tests/test_ip_parse_build.salt
// IPv4 Header Parse/Build Round-Trip — Unit Test
// =============================================================================
//
// Verifies the byte-level IPv4 header contract (20 bytes, no options):
//   [4b ver|4b IHL][TOS][Total Len (BE)][ID][Flags|FragOff]
//   [TTL][Proto][Checksum (BE)][Src IP (BE)][Dst IP (BE)]
//
// Also validates the RFC 1071 Internet Checksum: a correctly built header
// must self-check to 0x0000 when the checksum is recomputed over all 20 bytes.
// =============================================================================

package main

use std.core.ptr.Ptr

extern fn puts(s: Ptr<u8>) -> i32;
extern fn malloc(size: i64) -> u64;
extern fn free(ptr: u64);
extern fn exit(code: i32);

// --- Pure functions under test (mirror of kernel/net/ip.salt) ----------------

struct IPv4Header {
    src_ip: u32,
    dst_ip: u32,
    protocol: u8,
    total_len: u16,
    ttl: u8,
    ihl: u8,
}

fn checksum(buf: u64, len: u32) -> u16 {
    let mut sum: u32 = 0;
    let mut i: u32 = 0;

    while i + 1 < len {
        let hi = *((buf + i as u64) as &u8) as u32;
        let lo = *((buf + i as u64 + 1) as &u8) as u32;
        sum = sum + ((hi << 8) | lo);
        i = i + 2;
    }

    if i < len {
        let hi = *((buf + i as u64) as &u8) as u32;
        sum = sum + (hi << 8);
    }

    while (sum >> 16) != 0 {
        sum = (sum & 0xFFFF) + (sum >> 16);
    }

    return (sum ^ 0xFFFF) as u16;
}

fn ip_parse(buf: u64, len: u32) -> IPv4Header {
    let mut hdr = IPv4Header {
        src_ip: 0,
        dst_ip: 0,
        protocol: 0,
        total_len: 0,
        ttl: 0,
        ihl: 0,
    };

    if len < 20 {
        return hdr;
    }

    let byte0 = *(buf as &u8);
    hdr.ihl = (byte0 & 0x0F) * 4;

    let tl_hi = *((buf + 2) as &u8) as u16;
    let tl_lo = *((buf + 3) as &u8) as u16;
    hdr.total_len = (tl_hi << 8) | tl_lo;

    hdr.ttl = *((buf + 8) as &u8);
    hdr.protocol = *((buf + 9) as &u8);

    let s0 = *((buf + 12) as &u8) as u32;
    let s1 = *((buf + 13) as &u8) as u32;
    let s2 = *((buf + 14) as &u8) as u32;
    let s3 = *((buf + 15) as &u8) as u32;
    hdr.src_ip = (s0 << 24) | (s1 << 16) | (s2 << 8) | s3;

    let d0 = *((buf + 16) as &u8) as u32;
    let d1 = *((buf + 17) as &u8) as u32;
    let d2 = *((buf + 18) as &u8) as u32;
    let d3 = *((buf + 19) as &u8) as u32;
    hdr.dst_ip = (d0 << 24) | (d1 << 16) | (d2 << 8) | d3;

    return hdr;
}

fn ip_build(buf: u64, src_ip: u32, dst_ip: u32, protocol: u8, payload_len: u16) -> u32 {
    let total_len: u16 = 20 + payload_len;

    *(buf as &mut u8) = 0x45;
    *((buf + 1) as &mut u8) = 0;
    *((buf + 2) as &mut u8) = (total_len >> 8) as u8;
    *((buf + 3) as &mut u8) = (total_len & 0xFF) as u8;
    *((buf + 4) as &mut u8) = 0;
    *((buf + 5) as &mut u8) = 0;
    *((buf + 6) as &mut u8) = 0x40;
    *((buf + 7) as &mut u8) = 0;
    *((buf + 8) as &mut u8) = 64;
    *((buf + 9) as &mut u8) = protocol;
    *((buf + 10) as &mut u8) = 0;
    *((buf + 11) as &mut u8) = 0;
    *((buf + 12) as &mut u8) = ((src_ip >> 24) & 0xFF) as u8;
    *((buf + 13) as &mut u8) = ((src_ip >> 16) & 0xFF) as u8;
    *((buf + 14) as &mut u8) = ((src_ip >> 8) & 0xFF) as u8;
    *((buf + 15) as &mut u8) = (src_ip & 0xFF) as u8;
    *((buf + 16) as &mut u8) = ((dst_ip >> 24) & 0xFF) as u8;
    *((buf + 17) as &mut u8) = ((dst_ip >> 16) & 0xFF) as u8;
    *((buf + 18) as &mut u8) = ((dst_ip >> 8) & 0xFF) as u8;
    *((buf + 19) as &mut u8) = (dst_ip & 0xFF) as u8;

    let csum = checksum(buf, 20);
    *((buf + 10) as &mut u8) = (csum >> 8) as u8;
    *((buf + 11) as &mut u8) = (csum & 0xFF) as u8;

    return 20;
}

// --- Test helpers -----------------------------------------------------------

fn fail(msg: Ptr<u8>) {
    puts(msg);
    exit(1);
}

// --- Tests ------------------------------------------------------------------

fn main() -> i32 {
    let buf = malloc(64);
    if buf == 0 {
        fail("FAIL: malloc returned null" as Ptr<u8>);
        return 1;
    }

    let mut z: i32 = 0;
    while z < 64 {
        *((buf + z as u64) as &mut u8) = 0;
        z = z + 1;
    }

    // ---- Test 1: Build→Parse round-trip ------------------------------------
    // src=10.0.2.15 (0x0A00020F), dst=10.0.2.2 (0x0A000202), proto=17 (UDP)
    let src_ip: u32 = 0x0A00020F;
    let dst_ip: u32 = 0x0A000202;

    let sz = ip_build(buf, src_ip, dst_ip, 17, 100);
    if sz != 20 {
        fail("FAIL: ip_build did not return 20" as Ptr<u8>);
    }

    let hdr = ip_parse(buf, 20);
    if hdr.src_ip != src_ip {
        fail("FAIL: parsed src_ip mismatch" as Ptr<u8>);
    }
    if hdr.dst_ip != dst_ip {
        fail("FAIL: parsed dst_ip mismatch" as Ptr<u8>);
    }
    if hdr.protocol != 17 {
        fail("FAIL: parsed protocol mismatch" as Ptr<u8>);
    }

    // ---- Test 2: IHL correctness -------------------------------------------
    if hdr.ihl != 20 {
        fail("FAIL: parsed IHL != 20" as Ptr<u8>);
    }

    // ---- Test 3: TTL -------------------------------------------------------
    if hdr.ttl != 64 {
        fail("FAIL: parsed TTL != 64" as Ptr<u8>);
    }

    // ---- Test 4: Total length ----------------------------------------------
    // total_len = 20 (header) + 100 (payload) = 120
    if hdr.total_len != 120 {
        fail("FAIL: parsed total_len != 120" as Ptr<u8>);
    }

    // ---- Test 5: Checksum self-validation ----------------------------------
    // A correctly built header must self-check to 0x0000
    let csum = checksum(buf, 20);
    if csum != 0 {
        fail("FAIL: checksum of built header != 0x0000" as Ptr<u8>);
    }

    // ---- Test 6: Short buffer rejection ------------------------------------
    let hdr2 = ip_parse(buf, 19);
    if hdr2.src_ip != 0 {
        fail("FAIL: short buffer should return zeroed header" as Ptr<u8>);
    }

    free(buf);
    puts("PASS: all ip tests" as Ptr<u8>);
    return 0;
}
